    def on_category_toggle(self, widget, cat_id, cat_box):
        """Toggle category expansion (accordion - only one open at a time)"""
        is_currently_expanded = self.expanded_categories.get(cat_id, False)
        
        # Close all categories first
        for key in self.expanded_categories:
            self.expanded_categories[key] = False
        
        # Toggle the clicked one (if it was closed, open it)
        if not is_currently_expanded:
            self.expanded_categories[cat_id] = True
        
        self.rebuild_mode_section()
    
    def on_mode_clicked(self, widget, mode):
        """Launch selected mode"""
        mode_id = mode['id']
        mode_name = mode['name']
        
        print(f"Launching mode: {mode_name} ({mode_id})")
        
        # Check radio BEFORE launching ANY mode
        if not self._check_radio_before_launch(mode_name):
            return  # Radio not ready, error already shown
        
        # Add to recent
        self.add_to_recent(mode_id)
        
        # Update current mode display
        self.current_mode_label.set_text(f"→ {mode_name}")
        
        # Launch based on mode type
        try:
            if mode_id.startswith('winlink-'):
                self.launch_winlink_mode(mode)
            elif mode_id == 'js8call':
                self.launch_js8call()
            elif mode_id == 'varac':
                self.launch_varac()
            elif mode_id == 'ft8':
                self.launch_wsjtx()
            elif mode_id == 'fldigi':
                self.launch_fldigi()
            elif mode_id == 'chattervox':
                self.launch_chattervox()
            elif mode_id == 'bbs-client':
                self.launch_bbs_client_paracon()
            elif mode_id == 'bbs-client2':
                self.launch_bbs_client_qttermtcp()
            elif mode_id == 'bbs-server':
                self.launch_bbs_server()
            elif mode_id == 'aprs-client':
                self.launch_aprs()
            elif mode_id in ['flmsg', 'flamp']:
                self.launch_nbems(mode_id)
            else:
                print(f"Unknown mode: {mode_id}")
        except Exception as e:
            print(f"Error launching {mode_name}: {e}")
            self.show_error_dialog(f"Error launching {mode_name}", str(e))
    
    def launch_winlink_mode(self, mode):
        """Launch Winlink with specified modem using wait_for_port"""
        modem = mode.get('modem', 'vara-hf')
        mode_name = mode['name']
        
        print(f"Starting Winlink with modem: {modem}")
        
        MODE_STATUS_FILE.parent.mkdir(parents=True, exist_ok=True)
        MODE_STATUS_FILE.write_text(f"winlink-{modem}")
        
        # Kill existing services
        subprocess.run(["/opt/emcomm-tools/bin/et-kill-all"], capture_output=True)
        
        # Show starting message
        self.current_mode_label.set_text(f"→ Starting {mode_name}...")
        
        # Store modem for callback
        self._winlink_modem = modem
        
        def start_services():
            if modem in ['vara-hf', 'vara-fm']:
                # Start VARA and wait for port 8300
                vara_type = 'hf' if modem == 'vara-hf' else 'fm'
                vara_script = f"/opt/emcomm-tools/bin/et-vara-{vara_type}"
                
                if os.path.exists(vara_script):
                    # CRITICAL: Must set WINEPREFIX for Wine apps!
                    subprocess.Popen([vara_script], env=get_wine_env(), start_new_session=True)
                    
                
                # Wait for VARA command port
                if wait_for_port(8300, timeout=60):
                    GLib.idle_add(self._launch_winlink_app)
                else:
                    GLib.idle_add(self._show_service_error, f"Winlink ({modem})", "VARA not ready on port 8300")
                    
            elif modem == '1200' or modem == 'packet':
                # Packet mode - start Direwolf and wait for port 8001
                success, msg = start_and_wait_for_service(
                    "et-service-direwolf-simple",
                    timeout=30,
                    wait_port=8001
                )
                if success:
                    GLib.idle_add(self._launch_winlink_app)
                else:
                    GLib.idle_add(self._show_service_error, "Winlink (Packet)", msg)
                    
            elif modem == 'ardop':
                # Start ARDOP and wait for port 8515
                ardop_script = "/opt/emcomm-tools/bin/et-ardop"
                if os.path.exists(ardop_script):
                    subprocess.Popen([ardop_script, "start"], start_new_session=True)
                else:
                    subprocess.run(["systemctl", "--user", "start", "et-service-ardop"])
                
                # Wait for ARDOP command port
                if wait_for_port(8515, timeout=30):
                    GLib.idle_add(self._launch_winlink_app)
                else:
                    GLib.idle_add(self._show_service_error, "Winlink (ARDOP)", "ARDOP not ready on port 8515")
            
            return False
        
        import threading
        thread = threading.Thread(target=start_services)
        thread.daemon = True
        thread.start()
    
    def _launch_winlink_app(self):
        """Launch Pat Winlink via et-winlink script after modem is ready"""
        modem = getattr(self, '_winlink_modem', 'vara-hf')
        self.current_mode_label.set_text(f"→ Winlink ({modem})")
        
        # Map modem to et-winlink command
        modem_cmd_map = {
            'vara-hf': 'start-vara-hf',
            'vara-fm': 'start-vara-fm',
            '1200': 'start-packet',
            'packet': 'start-packet',
            'ardop': 'start-ardop',
        }
        
        winlink_cmd = modem_cmd_map.get(modem, 'start-vara-hf')
        et_winlink = "/opt/emcomm-tools/bin/et-winlink"
        
        # Call et-winlink script which handles Pat config and browser launch
        if os.path.exists(et_winlink):
            subprocess.Popen([et_winlink, winlink_cmd], start_new_session=True)
        else:
            # Fallback: start pat http directly
            subprocess.Popen(["pat", "http"], start_new_session=True)
            if wait_for_port(8080, timeout=15):
                subprocess.Popen(["xdg-open", "http://localhost:8080"], start_new_session=True)
    
