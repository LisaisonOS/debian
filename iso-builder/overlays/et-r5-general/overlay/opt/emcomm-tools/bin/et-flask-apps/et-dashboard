    def run_command(self, cmd):
        try:
            result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=5)
            return result.stdout.strip()
        except Exception:
            return ""
    
    def update_info(self):
        # UTC Time
        utc = self.run_command("date -u '+%H:%M:%S'")
        self.utc_label.set_text(f"UTC: {utc}")
        
        # GPS Status
        gps = self.run_command("et-system-info et-gps 2>/dev/null")
        if gps and "not" not in gps.lower():
            self.gps_label.set_markup("<span foreground='#00CC00'>GPS: ✓</span>")
        else:
            self.gps_label.set_markup("<span foreground='#CC0000'>GPS: ✗</span>")
        
        # Radio
        radio = self.run_command("et-system-info active-radio 2>/dev/null") or "Not configured"
        self.radio_label.set_markup(f"<span foreground='#888888'>Radio: {radio}</span>")
        
        # CAT
        cat = self.run_command("et-system-info et-cat 2>/dev/null")
        if cat and "not" not in cat.lower():
            self.cat_label.set_markup("<span foreground='#888888'>CAT: </span><span foreground='#00CC00'>✓</span>")
        else:
            self.cat_label.set_markup("<span foreground='#888888'>CAT: </span><span foreground='#CC0000'>✗</span>")
        
        # Audio
        audio = self.run_command("et-system-info et-audio 2>/dev/null")
        if audio and "not" not in audio.lower():
            self.audio_label.set_markup("<span foreground='#888888'>Audio: </span><span foreground='#00CC00'>✓</span>")
        else:
            self.audio_label.set_markup("<span foreground='#888888'>Audio: </span><span foreground='#CC0000'>✗</span>")
        
        # Operator info
        try:
            config = self.load_user_config()
            callsign = config.get("callsign", "N0CALL")
            grid = config.get("grid", "AA00aa")
        except Exception:
            callsign = "N0CALL"
            grid = "AA00aa"
        
        self.callsign_label.set_text(callsign)
        self.grid_label.set_text(f"· {grid}")
        
        # Current mode from status file
        try:
            if MODE_STATUS_FILE.exists():
                current = MODE_STATUS_FILE.read_text().strip()
                if current and not self.current_mode_label.get_text():
                    self.current_mode_label.set_text(f"● {current}")
        except Exception:
            pass
        
        return True
    
    def on_delete_event(self, widget, event):
        return True  # Prevent closing
    
    # === Flask App Launcher ===
    def launch_flask_app(self, app_name):
        """Launch a Flask/PyWebView app (prevent double-launch)"""
        # Check if already running
        if app_name in self.running_apps:
            proc = self.running_apps[app_name]
            if proc.poll() is None:  # Still running
                print(f"{app_name} is already running")
                return
            else:
                # Process finished, remove from tracking
                del self.running_apps[app_name]
        
        app_info = FLASK_APPS.get(app_name)
        if not app_info:
            return
        
        script = app_info['script']
        dashboard_dir = os.path.dirname(os.path.abspath(__file__))
        
        locations = [
            f"{dashboard_dir}/{app_name}/{script}",
            f"{FLASK_APPS_DIR}/{app_name}/{script}",
            f"/opt/emcomm-tools/share/{app_name}/{script}",
            os.path.expanduser(f"~/{app_name}/{script}"),
        ]
        
        for path in locations:
            if os.path.exists(path):
                proc = subprocess.Popen(["python3", path],
                               cwd=os.path.dirname(path),
                               start_new_session=True)
                self.running_apps[app_name] = proc
                return
        
        print(f"Could not find {app_name}")
    
    def on_radio_clicked(self, widget):
        self.launch_flask_app('et-radio')
    
    def on_user_clicked(self, widget):
        self.launch_flask_app('et-user')


