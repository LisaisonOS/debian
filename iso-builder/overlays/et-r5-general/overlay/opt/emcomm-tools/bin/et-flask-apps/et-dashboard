        self.user_config = self.load_user_config()
        self.recent_modes = self.user_config.get('recent_modes', [])
        self.language = self.user_config.get('language', 'en')
        
        # Track expanded categories
        self.expanded_categories = {}
        
        # Track running Flask apps (prevent double-launch)
        self.running_apps = {}
        
        # Get screen for adaptive sizing using modern Display/Monitor API
        self.display = Gdk.Display.get_default()
        self.monitor = self.display.get_primary_monitor() or self.display.get_monitor(0)
        geometry = self.monitor.get_geometry()
        self.screen_width = geometry.width
        self.screen_height = geometry.height
        
        # Keep screen reference for visual/CSS (still needed)
        self.screen = Gdk.Screen.get_default()
        
        self.calculate_adaptive_sizes()
        
        # Window setup - desktop widget style
        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_keep_below(True)
        self.set_type_hint(Gdk.WindowTypeHint.DOCK)
        self.stick()
        self.set_accept_focus(False)
        
        self.connect("delete-event", self.on_delete_event)
        # Monitor changes via display signal
        self.display.connect("monitor-added", self.on_monitor_changed)
        self.display.connect("monitor-removed", self.on_monitor_changed)
        
        # Approach 3: Listen to geometry/scale changes on the monitor itself
        if self.monitor:
            self.monitor.connect("notify::geometry", self.on_geometry_notify)
            self.monitor.connect("notify::scale-factor", self.on_geometry_notify)
        
        # Approach 1: Listen to window configure events (position/size changes)
        self.connect("configure-event", self.on_configure_event)
        
        # Track last known position to detect drift
        self._last_expected_x = None
        
        # Position top-right
        self.set_default_size(self.panel_width, -1)
        self.move(self.screen_width - self.panel_width - self.margin, self.margin)
        
        # Transparent background
        self.set_app_paintable(True)
        visual = self.screen.get_rgba_visual()
        if visual:
            self.set_visual(visual)
        
        self.apply_css()
        
        # Main container with scrolling for mode selector
        self.main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.main_box.set_name("dashboard")
        self.add(self.main_box)
        
        self.build_ui()
        
        # Auto-resize to fit content
        self.show_all()
        GLib.idle_add(self.auto_resize_height)
        
        # Start update timer
        GLib.timeout_add_seconds(2, self.update_info)
    
    def load_user_config(self):
        """Load user configuration."""
        if USER_CONFIG_FILE.exists():
            try:
                with open(USER_CONFIG_FILE, 'r') as f:
                    return json.load(f)
            except Exception as e:
                print(f"Warning: Could not load user config: {e}")
        return {}
    
    def save_user_config(self):
        """Save only recent_modes to user configuration (preserve other fields)."""
        ET_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        
        # Re-read the current config to preserve all fields
        current_config = {}
        if USER_CONFIG_FILE.exists():
            try:
                with open(USER_CONFIG_FILE, 'r') as f:
                    current_config = json.load(f)
            except Exception:
                pass
        
        # Only update recent_modes, preserve everything else
        current_config['recent_modes'] = self.recent_modes
        
        with open(USER_CONFIG_FILE, 'w') as f:
            json.dump(current_config, f, indent=2)
    
    def add_to_recent(self, mode_id):
        """Add mode to recent list."""
        if mode_id in self.recent_modes:
            self.recent_modes.remove(mode_id)
        self.recent_modes.insert(0, mode_id)
        self.recent_modes = self.recent_modes[:MAX_RECENT]
        self.save_user_config()
        self.rebuild_mode_section()
    
    def get_mode_by_id(self, mode_id):
        """Find mode definition by ID."""
        for cat_id, cat in MODE_CATEGORIES.items():
            for mode in cat['modes']:
                if mode['id'] == mode_id:
                    return mode, cat
        return None, None
    
