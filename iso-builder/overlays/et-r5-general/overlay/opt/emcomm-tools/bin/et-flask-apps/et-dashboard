        subprocess.run(["/opt/emcomm-tools/bin/et-kill-all"], capture_output=True)
        
        # Show starting message
        self.current_mode_label.set_text("→ Starting Direwolf...")
        
        def start_services():
            success, msg = start_and_wait_for_service(
                "et-service-direwolf-simple",
                timeout=30,
                wait_port=8001
            )
            
            if success:
                GLib.idle_add(self._launch_yaac_app)
            else:
                GLib.idle_add(self._show_service_error, "APRS (YAAC)", msg)
            
            return False
        
        import threading
        thread = threading.Thread(target=start_services)
        thread.daemon = True
        thread.start()
    
    def _launch_yaac_app(self):
        """Actually launch YAAC after Direwolf is ready"""
        self.current_mode_label.set_text("→ APRS (YAAC)")
        
        script_path = "/opt/emcomm-tools/bin/et-yaac"
        if os.path.exists(script_path):
            subprocess.Popen([script_path, "start"], start_new_session=True)
        else:
            # Try launching YAAC directly
            yaac_path = "/opt/yaac/YAAC.jar"
            if os.path.exists(yaac_path):
                subprocess.Popen(["java", "-jar", yaac_path], start_new_session=True)
    
    def launch_nbems(self, app):
        """Launch NBEMS apps (flmsg, flamp)"""
        MODE_STATUS_FILE.parent.mkdir(parents=True, exist_ok=True)
        MODE_STATUS_FILE.write_text(app)
        
        script_path = f"/opt/emcomm-tools/bin/et-{app}"
        if os.path.exists(script_path):
            subprocess.Popen([script_path, "start"], start_new_session=True)
        else:
            # Try direct launch
            subprocess.Popen([app], start_new_session=True)
    
    def show_modem_dialog(self, title, modems):
        """Show modem selection dialog - touch and mouse friendly"""
        dialog = Gtk.Dialog(
            title=f"Select Modem - {title}",
            transient_for=None,  # Don't link to dashboard to avoid resize
            flags=0
        )
        dialog.set_default_size(300, -1)
        dialog.set_modal(True)
        dialog.set_resizable(False)
        
        # Position dialog to the left of dashboard
        dialog_x = self.screen_width - self.panel_width - self.margin - 320
        dialog_y = 100
        dialog.move(dialog_x, dialog_y)
        
        # Make it appear above the dashboard
        dialog.set_keep_above(True)
        dialog.set_type_hint(Gdk.WindowTypeHint.DIALOG)
        
        content = dialog.get_content_area()
        content.set_spacing(10)
        content.set_margin_top(15)
        content.set_margin_bottom(15)
        content.set_margin_start(15)
        content.set_margin_end(15)
        
        # Modem labels
        modem_labels = {
            '1200': '📻 Packet 1200 baud',
            '9600': '📻 Packet 9600 baud',
            '300': '📻 Packet 300 baud (HF)',
            'vara-hf': '📡 VARA HF',
            'vara-fm': '📡 VARA FM',
            'ardop': '📡 ARDOP',
        }
        
        selected_modem = [None]
        
        for modem in modems:
            label = modem_labels.get(modem, modem)
            btn = Gtk.Button(label=label)
            btn.set_size_request(-1, 50)  # Touch-friendly height
            btn.connect("clicked", lambda w, m=modem: (selected_modem.__setitem__(0, m), dialog.response(Gtk.ResponseType.OK)))
            content.pack_start(btn, False, False, 0)
        
        # Cancel button
        cancel_btn = Gtk.Button(label="Cancel" if self.language == 'en' else "Annuler")
        cancel_btn.connect("clicked", lambda w: dialog.response(Gtk.ResponseType.CANCEL))
        content.pack_start(cancel_btn, False, False, 10)
        
        dialog.show_all()
        response = dialog.run()
        dialog.destroy()
        
        if response == Gtk.ResponseType.OK:
            return selected_modem[0]
        return None
    
    def show_status_dialog(self, title, message):
        """Show a brief status message"""
        dialog = Gtk.MessageDialog(
            transient_for=self,
            flags=0,
            message_type=Gtk.MessageType.INFO,
            buttons=Gtk.ButtonsType.OK,
            text=title
