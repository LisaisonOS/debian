@app.route('/save-winlink-password', methods=['POST'])
def save_winlink_password():
    """Save Winlink password to Pat config."""
    data = request.get_json()
    password = data.get('password', '').strip()
    
    if not password:
        return jsonify({'success': False, 'error': 'Password is required'})
    
    config = load_config()
    callsign = config.get('callsign', '')
    grid_square = config.get('grid', '')
    
    if not callsign:
        return jsonify({'success': False, 'error': 'Callsign not configured'})
    
    pat_config_dir = Path.home() / ".config" / "pat"
    pat_config_file = pat_config_dir / "config.json"
    
    pat_config_dir.mkdir(parents=True, exist_ok=True)
    
    if pat_config_file.exists():
        try:
            with open(pat_config_file, 'r') as f:
                pat_config = json.load(f)
        except Exception:
            pat_config = {}
    else:
        pat_config = {}
    
    pat_config['mycall'] = callsign.upper()
    pat_config['secure_login_password'] = password
    if grid_square:
        pat_config['locator'] = grid_square.upper()
    
    if 'http_addr' not in pat_config:
        pat_config['http_addr'] = '127.0.0.1:8080'
    
    try:
        with open(pat_config_file, 'w') as f:
            json.dump(pat_config, f, indent=2)
        
        config['winlink_configured'] = True
        save_config(config)
        
        return jsonify({'success': True})
    except Exception as e:
        return jsonify({'success': False, 'error': str(e)})


@app.route('/summary')
def summary():
    """Configuration summary page."""
    settings = load_settings()
    config = load_config()
    
    active_radio_id = get_active_radio()
    radio = get_radio_by_id(active_radio_id) if active_radio_id else None
    
    # Count downloaded maps
    et_maps_count = len([m for m in get_et_maps_status() if m['downloaded']])
    
    return render_template('summary.html',
                         lang=settings.get('language', 'en'),
                         config=config,
                         radio=radio,
                         services=SERVICES,
                         et_maps_count=et_maps_count)


