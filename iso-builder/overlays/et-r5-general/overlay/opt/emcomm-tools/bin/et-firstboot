# ============================================================================
# Internet Connectivity Check
# ============================================================================

def check_internet_connection() -> bool:
    """Check if internet is available."""
    test_urls = [
        "https://www.google.com",
        "https://github.com",
        "http://download.geofabrik.de"
    ]
    for url in test_urls:
        try:
            response = requests.head(url, timeout=5)
            if response.status_code < 400:
                return True
        except Exception:
            continue
    return False


# ============================================================================
# ET Maps Download Functions (mbtiles from GitHub)
# ============================================================================

def get_et_maps_download_url(filename: str) -> str:
    """Get full download URL for an ET map file."""
    return f"{ET_MAPS_BASE_URL}/{ET_MAPS_RELEASE}/{filename}"


def get_et_maps_status() -> List[Dict]:
    """Get status of ET map tilesets - which are downloaded."""
    maps_status = []
    MBTILES_LOCAL_DIR.mkdir(parents=True, exist_ok=True)
    
    for map_info in ET_MAPS_FILES:
        local_path = MBTILES_LOCAL_DIR / map_info["filename"]
        maps_status.append({
            **map_info,
            "downloaded": local_path.exists(),
            "local_path": str(local_path),
            "download_url": get_et_maps_download_url(map_info["filename"])
        })
    
    return maps_status


def download_et_map(filename: str, progress_id: str) -> Tuple[bool, str]:
    """Download an ET map tileset file with progress tracking."""
    global download_progress
    
    url = get_et_maps_download_url(filename)
    local_path = MBTILES_LOCAL_DIR / filename
    temp_path = MBTILES_LOCAL_DIR / f"{filename}.downloading"
    
    MBTILES_LOCAL_DIR.mkdir(parents=True, exist_ok=True)
    
    # Initialize progress
    download_progress[progress_id] = {
        "status": "starting",
        "percent": 0,
        "downloaded_mb": 0,
        "total_mb": 0,
        "filename": filename,
        "error": None
    }
    
    try:
        # Start download with streaming
        response = requests.get(url, stream=True, timeout=30)
        response.raise_for_status()
        
        total_size = int(response.headers.get('content-length', 0))
        total_mb = total_size / (1024 * 1024)
        downloaded = 0
        
        download_progress[progress_id]["status"] = "downloading"
        download_progress[progress_id]["total_mb"] = round(total_mb, 1)
        
        with open(temp_path, 'wb') as f:
            for chunk in response.iter_content(chunk_size=8192):
                if chunk:
                    f.write(chunk)
                    downloaded += len(chunk)
                    
                    # Update progress
                    downloaded_mb = downloaded / (1024 * 1024)
                    percent = (downloaded / total_size * 100) if total_size > 0 else 0
                    
                    download_progress[progress_id].update({
                        "downloaded_mb": round(downloaded_mb, 1),
                        "percent": round(percent, 1)
                    })
        
        # Move temp file to final location
        shutil.move(str(temp_path), str(local_path))
        
        download_progress[progress_id]["status"] = "complete"
        download_progress[progress_id]["percent"] = 100
        
        return True, f"Downloaded {filename}"
        
    except requests.RequestException as e:
        download_progress[progress_id]["status"] = "error"
        download_progress[progress_id]["error"] = str(e)
        
        # Clean up temp file
        if temp_path.exists():
            temp_path.unlink()
        
        return False, f"Download failed: {e}"


# ============================================================================
# Geofabrik OSM Download Functions (for Navit navigation)
# ============================================================================

def fetch_geofabrik_regions() -> List[Dict]:
    """Fetch available Canadian provinces/territories from Geofabrik."""
    regions = []
    
    try:
        response = requests.get(GEOFABRIK_INDEX_URL, timeout=15)
        response.raise_for_status()
        
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Find all .osm.pbf links (provinces)
        for link in soup.find_all('a', href=True):
            href = link['href']
            if href.endswith('.osm.pbf') and 'canada-latest' not in href:
                # Extract province name from filename
                filename = href
                name = filename.replace('-latest.osm.pbf', '').replace('-', ' ').title()
                
                regions.append({
                    "filename": filename,
                    "name": name,
                    "url": f"{GEOFABRIK_BASE_URL}/{filename}",
                    "downloaded": False  # Will be checked later
                })
        
        # Sort by name
        regions.sort(key=lambda x: x['name'])
        
    except Exception as e:
        print(f"Error fetching Geofabrik regions: {e}")
    
    return regions


def get_osm_maps_status() -> List[Dict]:
    """Get status of downloaded OSM maps."""
    OSM_LOCAL_DIR.mkdir(parents=True, exist_ok=True)
    NAVIT_MAPS_DIR.mkdir(parents=True, exist_ok=True)
    
    regions = fetch_geofabrik_regions()
    
    for region in regions:
        pbf_path = OSM_LOCAL_DIR / region["filename"]
        bin_filename = region["filename"].replace('.osm.pbf', '.osm.bin')
        bin_path = NAVIT_MAPS_DIR / bin_filename
        
        region["pbf_downloaded"] = pbf_path.exists()
        region["navit_converted"] = bin_path.exists()
        region["downloaded"] = region["pbf_downloaded"] or region["navit_converted"]
    
    return regions


def download_osm_map(filename: str, progress_id: str, convert_navit: bool = True) -> Tuple[bool, str]:
    """Download an OSM .pbf file and optionally convert for Navit."""
    global download_progress
    
    url = f"{GEOFABRIK_BASE_URL}/{filename}"
    local_path = OSM_LOCAL_DIR / filename
    temp_path = OSM_LOCAL_DIR / f"{filename}.downloading"
    
    OSM_LOCAL_DIR.mkdir(parents=True, exist_ok=True)
    NAVIT_MAPS_DIR.mkdir(parents=True, exist_ok=True)
    
    # Initialize progress
    download_progress[progress_id] = {
        "status": "starting",
        "percent": 0,
        "downloaded_mb": 0,
        "total_mb": 0,
        "filename": filename,
        "phase": "download",
        "error": None
    }
    
    try:
        # Start download with streaming
        response = requests.get(url, stream=True, timeout=30)
        response.raise_for_status()
        
        total_size = int(response.headers.get('content-length', 0))
        total_mb = total_size / (1024 * 1024)
        downloaded = 0
        
        download_progress[progress_id]["status"] = "downloading"
        download_progress[progress_id]["total_mb"] = round(total_mb, 1)
        
        with open(temp_path, 'wb') as f:
            for chunk in response.iter_content(chunk_size=8192):
                if chunk:
                    f.write(chunk)
                    downloaded += len(chunk)
                    
                    downloaded_mb = downloaded / (1024 * 1024)
                    percent = (downloaded / total_size * 100) if total_size > 0 else 0
                    
                    download_progress[progress_id].update({
                        "downloaded_mb": round(downloaded_mb, 1),
                        "percent": round(percent, 1)
                    })
        
        # Move temp file to final location
        shutil.move(str(temp_path), str(local_path))
        
        # Convert to Navit format if requested
        if convert_navit:
            download_progress[progress_id]["status"] = "converting"
            download_progress[progress_id]["phase"] = "navit"
            
            bin_filename = filename.replace('.osm.pbf', '.osm.bin')
            bin_path = NAVIT_MAPS_DIR / bin_filename
            
            try:
                result = subprocess.run(
                    ['maptool', '--protobuf', '-i', str(local_path), str(bin_path)],
                    capture_output=True, text=True, timeout=600
                )
                if result.returncode != 0:
                    download_progress[progress_id]["error"] = f"Navit conversion failed: {result.stderr}"
            except subprocess.TimeoutExpired:
                download_progress[progress_id]["error"] = "Navit conversion timed out"
            except FileNotFoundError:
                download_progress[progress_id]["error"] = "maptool not installed"
        
        download_progress[progress_id]["status"] = "complete"
        download_progress[progress_id]["percent"] = 100
        
        return True, f"Downloaded {filename}"
        
    except requests.RequestException as e:
        download_progress[progress_id]["status"] = "error"
        download_progress[progress_id]["error"] = str(e)
        
        if temp_path.exists():
            temp_path.unlink()
        
        return False, f"Download failed: {e}"


# ============================================================================
# Kiwix Wikipedia Download Functions
# ============================================================================

def fetch_wikipedia_files() -> List[Dict]:
    """Fetch available English Wikipedia .zim files from Kiwix."""
    files = []
    
    try:
        response = requests.get(KIWIX_INDEX_URL, timeout=15)
        response.raise_for_status()
        
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Find Wikipedia English .zim files (nopic versions to save space)
        for link in soup.find_all('a', href=True):
            href = link['href']
            if href.endswith('.zim') and 'wikipedia_en' in href and 'nopic' in href:
                # Filter to specific categories
                categories = ['computer', 'history', 'mathematics', 'medicine', 'simple']
                if any(cat in href.lower() for cat in categories):
                    # Extract readable name
                    name = href.replace('wikipedia_en_', '').replace('_nopic_', ' - ').replace('.zim', '')
                    name = name.replace('_', ' ').title()
                    
                    files.append({
                        "filename": href,
                        "name": name,
                        "url": f"{KIWIX_BASE_URL}/{href}",
                        "downloaded": False
                    })
        
        # Sort by name
        files.sort(key=lambda x: x['name'])
        
    except Exception as e:
        print(f"Error fetching Wikipedia files: {e}")
    
    return files


def get_wikipedia_status() -> List[Dict]:
    """Get status of downloaded Wikipedia files."""
    WIKIPEDIA_LOCAL_DIR.mkdir(parents=True, exist_ok=True)
    
    files = fetch_wikipedia_files()
    
    for file_info in files:
        local_path = WIKIPEDIA_LOCAL_DIR / file_info["filename"]
        file_info["downloaded"] = local_path.exists()
        file_info["local_path"] = str(local_path)
    
    return files


