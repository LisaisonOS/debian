    return jsonify({'drives': drives})


@app.route('/api/refresh-drives', methods=['POST'])
def refresh_drives():
    """Try to mount USB drives and return updated list."""
    try_mount_usb()
    time.sleep(1)
    drives = get_mounted_drives()
    return jsonify({'success': True, 'drives': drives})


@app.route('/api/open-file-manager', methods=['POST'])
def open_file_manager():
    """Open file manager to help user mount USB drive."""
    try:
        for fm in ['thunar', 'nautilus', 'pcmanfm', 'nemo', 'caja']:
            try:
                subprocess.Popen([fm, str(MEDIA_DIR)])
                return jsonify({'success': True, 'file_manager': fm})
            except FileNotFoundError:
                continue
        return jsonify({'success': False, 'error': 'No file manager found'})
    except Exception as e:
        return jsonify({'success': False, 'error': str(e)})


@app.route('/save-maps-config', methods=['POST'])
def save_maps_config():
    """Save maps configuration and setup symlinks."""
    data = request.get_json()
    drive_path = data.get('drive_path')
    skip = data.get('skip', False)
    
    config = load_config()
    
    if skip:
        config['maps_drive'] = None
        config['maps_configured'] = False
        save_config(config)
        return jsonify({'success': True, 'skipped': True})
    
    if not drive_path:
        return jsonify({'success': False, 'error': 'No drive selected'})
    
    if not Path(drive_path).exists():
        return jsonify({'success': False, 'error': 'Drive no longer accessible'})
    
    try:
        create_drive_structure(drive_path)
        results = setup_maps_symlinks(drive_path)
        
        config['maps_drive'] = drive_path
        config['maps_configured'] = True
        save_config(config)
        
        return jsonify({
            'success': True,
            'results': results,
            'drive': Path(drive_path).name
        })
    except Exception as e:
        return jsonify({'success': False, 'error': str(e)})


