# ============================================================================
# Main
# ============================================================================

def run_flask(port):
    """Run Flask server in background thread (silently)."""
    import os
    cli = sys.modules.get('flask.cli')
    if cli:
        cli.show_server_banner = lambda *args, **kwargs: None
    
    with open(os.devnull, 'w') as devnull:
        old_stdout, old_stderr = sys.stdout, sys.stderr
        sys.stdout, sys.stderr = devnull, devnull
        try:
            app.run(host='127.0.0.1', port=port, debug=False, use_reloader=False)
        finally:
            sys.stdout, sys.stderr = old_stdout, old_stderr


def open_browser(port):
    """Open browser after short delay."""
    time.sleep(1)
    webbrowser.open(f'http://127.0.0.1:{port}')


if __name__ == '__main__':
    port = 5051
    
    force_mode = '--force' in sys.argv
    if force_mode and FIRSTBOOT_FLAG.exists():
        FIRSTBOOT_FLAG.unlink()
        print("Firstboot flag removed, will re-run wizard")
    
    if '--no-browser' in sys.argv:
        app.run(host='127.0.0.1', port=port, debug=False)
    elif '--browser' in sys.argv:
        threading.Thread(target=open_browser, args=(port,), daemon=True).start()
        print(f"Starting First Boot Wizard on http://127.0.0.1:{port}")
        app.run(host='127.0.0.1', port=port, debug=False)
    elif '--help' in sys.argv:
        print("Usage: et-firstboot [OPTIONS]")
        print("")
        print("Options:")
        print("  --no-browser    Start server only (no window)")
        print("  --browser       Open in default web browser")
        print("  --force         Force re-run even if already completed")
        print("  --help          Show this help message")
        print("")
        print("Default: Opens in native PyWebView window")
        sys.exit(0)
    else:
        try:
            import webview
            
            win_width = 600
            win_height = 800
            
            try:
                import gi
                gi.require_version('Gdk', '3.0')
                from gi.repository import Gdk
                
                display = Gdk.Display.get_default()
                monitor = display.get_primary_monitor() or display.get_monitor(0)
                geometry = monitor.get_geometry()
                screen_width = geometry.width
                screen_height = geometry.height
                
                if screen_width >= 1920:
                    dashboard_width = 380
                    margin = 10
                    taskbar_height = 50
                elif screen_width >= 1680:
                    dashboard_width = 340
                    margin = 8
                    taskbar_height = 48
                elif screen_width >= 1366:
                    dashboard_width = 300
                    margin = 8
                    taskbar_height = 45
                else:
                    dashboard_width = 280
                    margin = 5
                    taskbar_height = 40
                
                win_height = screen_height - margin - taskbar_height
                x = screen_width - dashboard_width - margin - win_width - margin
                y = margin
            except:
                x = None
                y = None
            
            flask_thread = threading.Thread(target=run_flask, args=(port,), daemon=True)
            flask_thread.start()
            
            time.sleep(1)
            
            window = webview.create_window(
                'EmComm-Tools - First Boot',
                f'http://127.0.0.1:{port}',
                width=win_width,
                height=win_height,
                resizable=True,
                min_size=(500, 600),
                x=x,
                y=y,
                frameless=True
            )
            webview.start()
            
        except ImportError:
            print("PyWebView not installed. Falling back to browser mode.")
            threading.Thread(target=open_browser, args=(port,), daemon=True).start()
            app.run(host='127.0.0.1', port=port, debug=False)
