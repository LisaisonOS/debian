@app.route('/maps-setup')
def maps_setup():
    """Maps configuration page - download or link to USB."""
    settings = load_settings()
    config = load_config()
    
    # Check internet connectivity
    has_internet = check_internet_connection()
    
    # Enable USB automount
    enable_usb_automount()
    try_mount_usb()
    
    # Get available drives
    drives = get_mounted_drives()
    
    # Get download status for each category
    et_maps = get_et_maps_status() if has_internet else []
    
    return render_template('maps_setup.html',
                         lang=settings.get('language', 'en'),
                         callsign=config.get('callsign', ''),
                         has_internet=has_internet,
                         drives=drives,
                         et_maps=et_maps,
                         selected_drive=config.get('maps_drive'))


@app.route('/maps-download')
def maps_download():
    """Dedicated page for downloading maps with more options."""
    settings = load_settings()
    config = load_config()
    
    has_internet = check_internet_connection()
    
    if not has_internet:
        return redirect(url_for('maps_setup'))
    
    # Get all available downloads
    et_maps = get_et_maps_status()
    osm_maps = get_osm_maps_status()
    wikipedia_files = get_wikipedia_status()
    
    return render_template('maps_download.html',
                         lang=settings.get('language', 'en'),
                         callsign=config.get('callsign', ''),
                         has_internet=has_internet,
                         et_maps=et_maps,
                         osm_maps=osm_maps,
                         wikipedia_files=wikipedia_files)


