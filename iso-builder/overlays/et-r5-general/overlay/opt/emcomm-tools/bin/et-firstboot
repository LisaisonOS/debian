@app.route('/api/download/et-map', methods=['POST'])
def api_download_et_map():
    """Start download of an ET map tileset."""
    data = request.get_json()
    filename = data.get('filename')
    
    if not filename:
        return jsonify({'success': False, 'error': 'No filename specified'})
    
    progress_id = f"et-map-{filename}"
    
    # Start download in background thread
    thread = threading.Thread(
        target=download_et_map,
        args=(filename, progress_id),
        daemon=True
    )
    thread.start()
    
    return jsonify({'success': True, 'progress_id': progress_id})


@app.route('/api/download/osm-map', methods=['POST'])
def api_download_osm_map():
    """Start download of an OSM map."""
    data = request.get_json()
    filename = data.get('filename')
    convert_navit = data.get('convert_navit', True)
    
    if not filename:
        return jsonify({'success': False, 'error': 'No filename specified'})
    
    progress_id = f"osm-map-{filename}"
    
    thread = threading.Thread(
        target=download_osm_map,
        args=(filename, progress_id, convert_navit),
        daemon=True
    )
    thread.start()
    
    return jsonify({'success': True, 'progress_id': progress_id})


@app.route('/api/download/wikipedia', methods=['POST'])
def api_download_wikipedia():
    """Start download of a Wikipedia file."""
    data = request.get_json()
    filename = data.get('filename')
    
    if not filename:
        return jsonify({'success': False, 'error': 'No filename specified'})
    
    progress_id = f"wikipedia-{filename}"
    
    thread = threading.Thread(
        target=download_wikipedia,
        args=(filename, progress_id),
        daemon=True
    )
    thread.start()
    
    return jsonify({'success': True, 'progress_id': progress_id})


@app.route('/api/download/progress/<progress_id>')
def api_download_progress(progress_id):
    """Get download progress for a specific download."""
    progress = download_progress.get(progress_id)
    
    if progress is None:
        return jsonify({'found': False})
    
    return jsonify({'found': True, **progress})


