def welcome():
    """Welcome/language selection page."""
    settings = load_settings()
    return render_template('welcome.html', lang=settings.get('language', 'en'))


@app.route('/set-language', methods=['POST'])
def set_language():
    """Set language preference."""
    data = request.get_json()
    lang = data.get('language', 'en')
    
    settings = load_settings()
    settings['language'] = lang
    save_settings(settings)
    session['language'] = lang
    
    return jsonify({'success': True, 'language': lang})


@app.route('/operator')
def operator():
    """Operator information page."""
    settings = load_settings()
    config = load_config()
    
    return render_template('operator.html',
                         lang=settings.get('language', 'en'),
                         callsign=config.get('callsign', ''),
                         grid=config.get('grid', ''),
                         name=config.get('name', ''))


@app.route('/save-operator', methods=['POST'])
def save_operator():
    """Save operator information."""
    data = request.get_json()
    callsign = data.get('callsign', '').strip()
    grid_square = data.get('grid_square', '').strip()
    name = data.get('name', '').strip()
    
    valid, result = validate_callsign(callsign)
    if not valid:
        return jsonify({'success': False, 'error': result, 'field': 'callsign'})
    callsign = result
    
    valid, result = validate_grid_square(grid_square)
    if not valid:
        return jsonify({'success': False, 'error': result, 'field': 'grid_square'})
    grid_square = result
    
    config = load_config()
    config['callsign'] = callsign
    config['grid'] = grid_square
    config['name'] = name
    save_config(config)
    
    return jsonify({'success': True})


@app.route('/radio')
def radio():
    """Radio selection page."""
    settings = load_settings()
    config = load_config()
    radios = load_radios()
    active_radio = get_active_radio()
    
    return render_template('radio.html',
                         lang=settings.get('language', 'en'),
                         callsign=config.get('callsign', ''),
                         radios=radios,
                         active_radio=active_radio)


@app.route('/save-radio', methods=['POST'])
def save_radio():
    """Save selected radio."""
    data = request.get_json()
    radio_id = data.get('radio_id', 'none')
    
    success = set_active_radio(radio_id)
    
    if success:
        config = load_config()
        config['active_radio'] = radio_id if radio_id != 'none' else None
        save_config(config)
        
        if radio_id and radio_id != 'none':
            radio = get_radio_by_id(radio_id)
            return jsonify({'success': True, 'radio_id': radio_id, 'radio': radio})
        else:
            return jsonify({'success': True, 'radio_id': None})
    else:
        return jsonify({'success': False, 'error': 'Failed to set radio'})


