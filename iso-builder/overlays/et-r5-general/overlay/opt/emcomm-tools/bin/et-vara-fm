#!/bin/bash
# Author  : Gaston Gonzalez
# Date    : 20 January 2025
# Updated : 23 January 2026
# Purpose : Run VARA FM with auto-configuration for PTT

# Modified by: Sylvain Deguire - VA2OPS
# Comments: Added VARAFM.ini PTT configuration from radio JSON 
#           Added TCP listening verification and diagnostics
#           Added --monitor mode for continuous connection monitoring

source /opt/emcomm-tools/bin/et-common

EXE="${HOME}/.wine32/drive_c/VARA FM/VARAFM.exe"
VARA_INI="${HOME}/.wine32/drive_c/VARA FM/VARAFM.ini"
WINEPREFIX="${HOME}/.wine32"

# Default PTT Configuration (used if not in radio config)
DEFAULT_PTT_PORT="COM5"
DEFAULT_PTT_VIA="2"        # 0=VOX, 1=CAT, 2=COM (RTS/DTR), 3=CM108
DEFAULT_PTT_RTS="1"        # 1=enabled
DEFAULT_PTT_DTR="0"        # 0=disabled

# TCP Port for VARA FM (will be read from INI)
VARA_TCP_PORT="8300"

# Monitoring settings
MONITOR_MODE=0
MONITOR_INTERVAL=5

# =============================================================================
# FUNCTIONS
# =============================================================================

# Display usage
show_usage() {
  echo -e "Usage: et-vara-fm [OPTIONS]"
  echo -e ""
  echo -e "Options:"
  echo -e "  --monitor, -m     Run in monitor mode (continuous TCP status)"
  echo -e "  --interval, -i N  Monitor interval in seconds (default: 5)"
  echo -e "  --help, -h        Show this help"
  echo -e ""
  echo -e "Examples:"
  echo -e "  et-vara-fm                  # Normal start"
  echo -e "  et-vara-fm --monitor        # Start with monitoring"
  echo -e "  et-vara-fm -m -i 10         # Monitor every 10 seconds"
}

# Display banner
show_banner() {
  echo -e "${BLUE}============================================${NC}"
  echo -e "${BLUE}       VARA FM Launcher - EmComm-Tools      ${NC}"
  echo -e "${BLUE}============================================${NC}"
}

# Read TCP port from VARAFM.ini
read_tcp_port_from_ini() {
  if [[ -f "${VARA_INI}" ]]; then
    local port=$(grep "^TCP Command Port=" "${VARA_INI}" | cut -d'=' -f2 | tr -d '\r\n ')
    if [[ -n "${port}" ]]; then
      VARA_TCP_PORT="${port}"
    fi
  fi
  echo -e "${GREEN}  ✓ TCP Port: ${VARA_TCP_PORT}${NC}"
}

# Check serial/PTT device
check_serial_device() {
  echo -e "${YELLOW}[CHECK]${NC} Serial/PTT device..."
  
  if [[ -e /dev/ttyUSB0 ]]; then
    echo -e "${GREEN}  ✓ /dev/ttyUSB0 found${NC}"
  else
    echo -e "${RED}  ✗ /dev/ttyUSB0 not found${NC}"
  fi
  
  # Check Wine COM port symlink
  if [[ -L "${WINEPREFIX}/dosdevices/com5" ]]; then
    local target=$(readlink "${WINEPREFIX}/dosdevices/com5")
    echo -e "${GREEN}  ✓ Wine COM5 -> ${target}${NC}"
  else
    echo -e "${YELLOW}  ! Wine COM5 symlink not found${NC}"
  fi
}

# Check audio device
check_audio_device() {
  echo -e "${YELLOW}[CHECK]${NC} Audio device..."
  
  if [[ -e /dev/et-audio ]]; then
    echo -e "${GREEN}  ✓ /dev/et-audio found${NC}"
    
    # Get device details
    local audio_info=$(arecord -l 2>/dev/null | grep -i usb | head -1)
    if [[ -n "${audio_info}" ]]; then
      echo -e "${GREEN}  ✓ ${audio_info}${NC}"
    fi
  else
    echo -e "${RED}  ✗ /dev/et-audio not found${NC}"
    return 1
  fi
  
  return 0
}

# Read VARA FM PTT settings from active radio config
read_radio_config() {
  echo -e "${YELLOW}[CHECK]${NC} Radio configuration..."
  
  if [[ ! -f "${ET_ACTIVE_RADIO_CONF}" ]]; then
    echo -e "${YELLOW}  ! No active radio config found, using defaults${NC}"
    PTT_PORT="${DEFAULT_PTT_PORT}"
    PTT_VIA="${DEFAULT_PTT_VIA}"
    PTT_RTS="${DEFAULT_PTT_RTS}"
    PTT_DTR="${DEFAULT_PTT_DTR}"
    return 0
  fi

  # Read varafm settings from JSON, fall back to defaults if not present
  PTT_PORT=$(jq -r '.varafm.pttPort // empty' "${ET_ACTIVE_RADIO_CONF}" 2>/dev/null)
  PTT_VIA=$(jq -r '.varafm.pttVia // empty' "${ET_ACTIVE_RADIO_CONF}" 2>/dev/null)
  PTT_RTS=$(jq -r '.varafm.rts // empty' "${ET_ACTIVE_RADIO_CONF}" 2>/dev/null)
  PTT_DTR=$(jq -r '.varafm.dtr // empty' "${ET_ACTIVE_RADIO_CONF}" 2>/dev/null)

  # Use defaults for any missing values
  PTT_PORT="${PTT_PORT:-${DEFAULT_PTT_PORT}}"
  PTT_VIA="${PTT_VIA:-${DEFAULT_PTT_VIA}}"
  PTT_RTS="${PTT_RTS:-${DEFAULT_PTT_RTS}}"
  PTT_DTR="${PTT_DTR:-${DEFAULT_PTT_DTR}}"

  # Get radio name for display
  RADIO_NAME=$(jq -r '"\(.vendor) \(.model)"' "${ET_ACTIVE_RADIO_CONF}" 2>/dev/null)
  if [[ -n "${RADIO_NAME}" && "${RADIO_NAME}" != "null null" ]]; then
    echo -e "${GREEN}  ✓ Active radio: ${RADIO_NAME}${NC}"
  fi

  return 0
}

# Calculate PTT Pin value from RTS/DTR settings
get_ptt_pin() {
  if [[ "${PTT_RTS}" == "1" && "${PTT_DTR}" == "0" ]]; then
    echo "1"  # RTS only
  elif [[ "${PTT_RTS}" == "0" && "${PTT_DTR}" == "1" ]]; then
    echo "2"  # DTR only
  elif [[ "${PTT_RTS}" == "1" && "${PTT_DTR}" == "1" ]]; then
    echo "3"  # RTS + DTR
  else
    echo "1"  # Default to RTS
  fi
}

# Update VARAFM.ini with correct PTT settings
update_vara_ini() {
  echo -e "${YELLOW}[CONFIG]${NC} Updating VARAFM.ini..."
  
  if [[ ! -f "${VARA_INI}" ]]; then
    echo -e "${YELLOW}  ! VARAFM.ini not found, will be created on first run${NC}"
    return 0
  fi

  local ptt_pin=$(get_ptt_pin)
  local ptt_via_text="UNKNOWN"
  case "${PTT_VIA}" in
    0) ptt_via_text="VOX" ;;
    1) ptt_via_text="CAT" ;;
    2) ptt_via_text="COM (RTS/DTR)" ;;
    3) ptt_via_text="CM108" ;;
  esac

  # Update PTT settings using sed
  sed -i "s/^PTTPort=.*/PTTPort=${PTT_PORT}/" "${VARA_INI}"
  sed -i "s/^Via=.*/Via=${PTT_VIA}/" "${VARA_INI}"
  sed -i "s/^RTS=.*/RTS=${PTT_RTS}/" "${VARA_INI}"
  sed -i "s/^DTR=.*/DTR=${PTT_DTR}/" "${VARA_INI}"
  sed -i "s/^Pin=.*/Pin=${ptt_pin}/" "${VARA_INI}"

  echo -e "${GREEN}  ✓ PTT Port: ${PTT_PORT}${NC}"
  echo -e "${GREEN}  ✓ PTT Via: ${ptt_via_text}${NC}"
  echo -e "${GREEN}  ✓ RTS: ${PTT_RTS}, DTR: ${PTT_DTR}${NC}"

  return 0
}

# Wait for TCP port to become available
wait_for_tcp() {
  local max_wait=30
  local wait_time=0
  local interval=2
  
  echo -e "${YELLOW}[WAIT]${NC} Waiting for TCP port ${VARA_TCP_PORT} to become available..."
  
  while [[ ${wait_time} -lt ${max_wait} ]]; do
    # Check Wine netstat - look for LISTENING or ESTABLISHED on our port
    local wine_status=$(WINEPREFIX="${WINEPREFIX}" wine netstat -an 2>/dev/null | grep ":${VARA_TCP_PORT}" | grep -iE "listen|established")
    
    if [[ -n "${wine_status}" ]]; then
      echo -e "${GREEN}  ✓ TCP port ${VARA_TCP_PORT} is now active (after ${wait_time}s)${NC}"
      return 0
    fi
    
    sleep ${interval}
    wait_time=$((wait_time + interval))
    echo -e "${YELLOW}  ... waiting (${wait_time}s/${max_wait}s)${NC}"
  done
  
  echo -e "${RED}  ✗ Timeout waiting for TCP port ${VARA_TCP_PORT}${NC}"
  return 1
}

# Get local IP address
get_local_ip() {
  hostname -I | awk '{print $1}'
}

# Show connection info
show_connection_info() {
  local ip=$(get_local_ip)
  echo -e "${BLUE}============================================${NC}"
  echo -e "${BLUE}           Connection Information           ${NC}"
  echo -e "${BLUE}============================================${NC}"
  echo -e "${WHITE}  VARA FM TCP: ${ip}:${VARA_TCP_PORT}${NC}"
  echo -e "${WHITE}  LinBPQ Config:${NC}"
  echo -e "${WHITE}    ADDR ${ip} ${VARA_TCP_PORT}${NC}"
  echo -e "${BLUE}============================================${NC}"
}

# Monitor TCP connections
monitor_tcp() {
  local ip=$(get_local_ip)
  local last_state=""
  local last_connections=""
  
  echo -e "${BLUE}============================================${NC}"
  echo -e "${BLUE}        VARA FM TCP Monitor (Ctrl+C to stop)${NC}"
  echo -e "${BLUE}============================================${NC}"
  echo -e "${WHITE}  Monitoring: ${ip}:${VARA_TCP_PORT}${NC}"
  echo -e "${WHITE}  Interval: ${MONITOR_INTERVAL}s${NC}"
  echo -e "${BLUE}============================================${NC}"
  echo ""
  
  while true; do
    local timestamp=$(date '+%H:%M:%S')
    
    # Get netstat output from Wine
    local netstat_out=$(WINEPREFIX="${WINEPREFIX}" wine netstat -an 2>/dev/null | grep ":${VARA_TCP_PORT}")
    
    # Check if listening
    local listening=$(echo "${netstat_out}" | grep -i "listen")
    
    # Check for established connections (external, not localhost to localhost)
    local established=$(echo "${netstat_out}" | grep -i "established")
    
    # Count connections
    local conn_count=0
    if [[ -n "${established}" ]]; then
      conn_count=$(echo "${established}" | grep -ci "established" 2>/dev/null || echo "0")
    fi
    
    # Determine state - ESTABLISHED also means the port is active
    local current_state=""
    if [[ -n "${listening}" ]] || [[ ${conn_count} -gt 0 ]]; then
      if [[ ${conn_count} -gt 0 ]]; then
        current_state="CONNECTED"
      else
        current_state="LISTENING"
      fi
    else
      # Check if there's any activity on our port at all
      if [[ -n "${netstat_out}" ]]; then
        current_state="ACTIVE"
      else
        current_state="NOT LISTENING"
      fi
    fi
    
    # Only print if state changed or connections changed
    if [[ "${current_state}" != "${last_state}" ]] || [[ "${established}" != "${last_connections}" ]]; then
      echo -e "${YELLOW}[${timestamp}]${NC} Status changed:"
      
      case "${current_state}" in
        "CONNECTED")
          echo -e "${GREEN}  ✓ Port ${VARA_TCP_PORT}: ACTIVE${NC}"
          echo -e "${GREEN}  ✓ Connections: ${conn_count}${NC}"
          # Show connection details
          echo "${established}" | while read line; do
            if [[ -n "${line}" ]]; then
              local remote=$(echo "${line}" | awk '{print $3}')
              echo -e "${GREEN}    → ${remote}${NC}"
            fi
          done
          ;;
        "LISTENING")
          echo -e "${GREEN}  ✓ Port ${VARA_TCP_PORT}: LISTENING${NC}"
          echo -e "${YELLOW}  ! No active connections${NC}"
          ;;
        "ACTIVE")
          echo -e "${GREEN}  ✓ Port ${VARA_TCP_PORT}: ACTIVE${NC}"
          ;;
        "NOT LISTENING")
          echo -e "${RED}  ✗ Port ${VARA_TCP_PORT}: NOT LISTENING${NC}"
          echo -e "${RED}    VARA FM may have crashed or TCP is disabled${NC}"
          ;;
      esac
      echo ""
      
      last_state="${current_state}"
      last_connections="${established}"
    fi
    
    sleep ${MONITOR_INTERVAL}
  done
}

# =============================================================================
# PARSE ARGUMENTS
# =============================================================================

while [[ $# -gt 0 ]]; do
  case "$1" in
    --monitor|-m)
      MONITOR_MODE=1
      shift
      ;;
    --interval|-i)
      MONITOR_INTERVAL="$2"
      shift 2
      ;;
    --help|-h)
      show_usage
      exit 0
      ;;
    *)
      echo -e "${RED}Unknown option: $1${NC}"
      show_usage
      exit 1
      ;;
  esac
done

# =============================================================================
# MAIN
# =============================================================================

show_banner

# Check if VARA FM executable exists
if [[ ! -e ${EXE} ]]; then
  echo -e "${RED}"
  echo -e "${EXE} does not exist."
  echo -e "You might NOT have installed the windows subsystem (WINE)."
  echo -e "Navigate to ${WHITE}${HOME}/add-ons/wine${RED} and follow the"
  echo -e "instructions in the ${WHITE}README.md${RED} file."
  echo -e "${NC}"
  exit 1
fi
echo -e "${GREEN}[OK]${NC} VARA FM executable found"

# 1. Check audio device
if ! check_audio_device; then
  echo -e "${RED}[FAIL]${NC} Audio device check failed"
  exit 1
fi

# Configure ALSA settings for sound card
APLAY_OUT=$(arecord -l | grep ET_AUDIO)
if [[ $? -eq 0 ]]; then
  echo -e "${YELLOW}[CONFIG]${NC} Configuring ALSA..."
  /opt/emcomm-tools/bin/et-audio update-config
  echo -e "${GREEN}  ✓ ALSA configured${NC}"
else
  echo -e "${RED}[FAIL]${NC} No ET_AUDIO device detected"
  exit 1
fi

# 2. Check serial device
check_serial_device

# 3. Read PTT configuration from active radio
read_radio_config

# 4. Update VARAFM.ini with PTT settings
update_vara_ini

# 5. Read TCP port from INI
echo -e "${YELLOW}[CONFIG]${NC} Reading TCP settings..."
read_tcp_port_from_ini

# 6. Kill any existing Wine processes
echo -e "${YELLOW}[CLEANUP]${NC} Stopping existing Wine processes..."
wineserver -k 2>/dev/null
sleep 1
echo -e "${GREEN}  ✓ Wine processes stopped${NC}"

# 7. Launch VARA FM in background
echo -e "${YELLOW}[LAUNCH]${NC} Starting VARA FM..."
WINEPREFIX="${WINEPREFIX}" wine "${EXE}" &
VARA_PID=$!
echo -e "${GREEN}  ✓ VARA FM started (PID: ${VARA_PID})${NC}"

# 8. Wait for TCP port to become available
sleep 3  # Give VARA FM time to initialize
if wait_for_tcp; then
  show_connection_info
  echo -e "${GREEN}[SUCCESS]${NC} VARA FM is ready!"
else
  echo -e "${RED}[WARNING]${NC} TCP port may not be available for remote connections"
  echo -e "${YELLOW}  Check VARA FM settings and try restarting${NC}"
fi

# 9. Enter monitor mode if requested
if [[ ${MONITOR_MODE} -eq 1 ]]; then
  echo ""
  monitor_tcp
else
  echo -e "${YELLOW}[INFO]${NC} VARA FM is running. Use --monitor for TCP monitoring."
  echo -e "${YELLOW}[INFO]${NC} Press Ctrl+C to stop."
  wait ${VARA_PID}
fi
