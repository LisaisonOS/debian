#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS) / Claude AI
# Date    : January 2026
# Purpose : Wrapper for et-auto-scale
#           - Live session: always run
#           - Installed system: run once on first boot only
#

MARKER_FILE="$HOME/.config/emcomm-tools/.auto-scale-done"
SCRIPT_PATH="/opt/emcomm-tools/bin/et-auto-scale"

# Check if running in live session
is_live_session() {
    # Check common live session indicators
    if [[ -f /run/live/medium/live ]] || \
       [[ -d /run/live ]] || \
       [[ -f /etc/live/boot.conf ]] || \
       grep -q "boot=live" /proc/cmdline 2>/dev/null; then
        return 0
    fi
    return 1
}

# Live session: always run
if is_live_session; then
    echo "[et-auto-scale-once] Live session detected, running auto-scale..."
    exec "$SCRIPT_PATH"
fi

# Installed system: check if already run
if [[ -f "$MARKER_FILE" ]]; then
    echo "[et-auto-scale-once] Already configured, skipping."
    exit 0
fi

# First boot on installed system: run and create marker
echo "[et-auto-scale-once] First boot detected, running auto-scale..."
"$SCRIPT_PATH"

# Create marker directory and file
mkdir -p "$(dirname "$MARKER_FILE")"
date > "$MARKER_FILE"
echo "[et-auto-scale-once] Marker created: $MARKER_FILE"

exit 0
