#!/bin/bash
#
# Author  : Gaston Gonzalez
# Date    : 3 November 2024
# Updated : 13 October 2025
# Purpose : Wrapper script for starting YAAC with PnP support
#
# Modified: Sylvain Deguire (VA2OPS)
# Date    : January 2026
# Changes : Added grid to lat/lon conversion for station position
#
# Preconditions:
# 1. Supported radio and audio interface are connected and properly detected
# 2. Dire Wolf is started or Bluetooth TNC is connected
#
# Postconditions:
# 1. Callsign is updated in YAAC
# 2. Station position is set from grid square
# 3. YAAC is started

YAAC_CONF_DIR=${HOME}/.java/.userPrefs/org/ka2ddo/yaac
YAAC_CONF_FILE_PORTS=${YAAC_CONF_DIR}/Ports/prefs.xml
YAAC_CONF_FILE_PORTS_TEMPLATE=/etc/skel/.java/.userPrefs/org/ka2ddo/yaac/Ports/prefs.xml
YAAC_CONF_FILE_PREFS=${YAAC_CONF_DIR}/prefs.xml

usage() {
  echo "usage: $(basename $0) <command>"
  echo "  <command>"
  echo "    start           - Start YAAC"
  echo "    update-config   - Update configuration for selected mode"
  echo "    grid-to-latlon  - Convert grid square to lat/lon (test)"
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

notify_user() {
  notify-send \
   -t 5000 \
   --app-name="EmComm Tools" \
   "$1"
}

# Convert Maidenhead grid square to latitude/longitude (center of grid)
# Usage: grid_to_latlon "FN35fl"
# Returns: "45.479167 -74.458333" (lat lon)
grid_to_latlon() {
    local grid="$1"
    
    # Validate grid format (4 or 6 characters)
    if [[ ! "$grid" =~ ^[A-Ra-r]{2}[0-9]{2}([A-Xa-x]{2})?$ ]]; then
        echo "ERROR: Invalid grid square format: $grid" >&2
        return 1
    fi
    
    # Convert to uppercase for field, lowercase for subsquare
    local field1=$(echo "${grid:0:1}" | tr 'a-r' 'A-R')
    local field2=$(echo "${grid:1:1}" | tr 'a-r' 'A-R')
    local square1="${grid:2:1}"
    local square2="${grid:3:1}"
    
    # Field: A=0 to R=17
    local lon_field=$(( $(printf '%d' "'$field1") - 65 ))
    local lat_field=$(( $(printf '%d' "'$field2") - 65 ))
    
    # Base longitude: field * 20 - 180
    # Base latitude: field * 10 - 90
    local lon=$(echo "scale=6; $lon_field * 20 - 180 + $square1 * 2" | bc)
    local lat=$(echo "scale=6; $lat_field * 10 - 90 + $square2 * 1" | bc)
    
    # If 6-character grid, add subsquare precision
    if [[ ${#grid} -ge 6 ]]; then
        local sub1=$(echo "${grid:4:1}" | tr 'A-X' 'a-x')
        local sub2=$(echo "${grid:5:1}" | tr 'A-X' 'a-x')
        
        # Subsquare: a=0 to x=23
        local lon_sub=$(( $(printf '%d' "'$sub1") - 97 ))
        local lat_sub=$(( $(printf '%d' "'$sub2") - 97 ))
        
        # Add subsquare offset + center offset
        # Each subsquare is 2/24 degrees lon, 1/24 degrees lat
        lon=$(echo "scale=6; $lon + $lon_sub * (2.0/24.0) + (1.0/24.0)" | bc)
        lat=$(echo "scale=6; $lat + $lat_sub * (1.0/24.0) + (1.0/48.0)" | bc)
    else
        # 4-character grid - use center of square
        lon=$(echo "scale=6; $lon + 1" | bc)
        lat=$(echo "scale=6; $lat + 0.5" | bc)
    fi
    
    echo "$lat $lon"
}

# Update YAAC station position from grid square
update_station_position() {
    local grid="$1"
    local callsign="$2"
    
    if [[ -z "$grid" || "$grid" == "null" ]]; then
        et-log "No grid square set, skipping station position update"
        return 0
    fi
    
    # Convert grid to lat/lon
    local coords=$(grid_to_latlon "$grid")
    if [[ $? -ne 0 ]]; then
        et-log "Failed to convert grid square: $grid"
        return 1
    fi
    
    local lat=$(echo "$coords" | cut -d' ' -f1)
    local lon=$(echo "$coords" | cut -d' ' -f2)
    
    et-log "Station position from grid $grid: Lat=$lat, Lon=$lon"
    
    # Create/update YAAC main prefs.xml with station position
    mkdir -p "${YAAC_CONF_DIR}"
    
    # Check if prefs.xml exists
    if [[ -f "$YAAC_CONF_FILE_PREFS" ]]; then
        # Update existing file - replace or add latitude/longitude entries
        # Remove old lat/lon entries if they exist
        sed -i '/<entry key="Latitude"/d' "$YAAC_CONF_FILE_PREFS"
        sed -i '/<entry key="Longitude"/d' "$YAAC_CONF_FILE_PREFS"
        sed -i '/<entry key="StationCallsign"/d' "$YAAC_CONF_FILE_PREFS"
        
        # Add new entries before </map>
        sed -i "s|</map>|  <entry key=\"Latitude\" value=\"$lat\"/>\n  <entry key=\"Longitude\" value=\"$lon\"/>\n  <entry key=\"StationCallsign\" value=\"$callsign\"/>\n</map>|" "$YAAC_CONF_FILE_PREFS"
        
        et-log "Updated existing YAAC preferences with station position"
    else
        # Create new prefs.xml
        cat > "$YAAC_CONF_FILE_PREFS" << EOF
<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE map SYSTEM "http://java.sun.com/dtd/preferences.dtd">
<map MAP_XML_VERSION="1.0">
  <entry key="Latitude" value="$lat"/>
  <entry key="Longitude" value="$lon"/>
  <entry key="StationCallsign" value="$callsign"/>
</map>
EOF
        et-log "Created new YAAC preferences with station position"
    fi
    
    return 0
}

start() {
  update-config
  
  if [[ $? -eq 0 ]]; then
    CMD="java -Xms2g -Xmx6g -XX:+UseG1GC -jar /opt/yaac/YAAC.jar"

    PS_OUT=$(ps -ef | grep "[r]fcomm0")
    if [[ $? -eq 0 ]]; then
      et-log "Starting YAAC in Bluetooth mode with: ${CMD}"
      ${CMD}
    fi

    PS_OUT=$(ps -ef | grep [d]irewolf)
    if [[ $? -eq 0 ]]; then
      et-log "Starting YAAC in Dire Wolf mode with: ${CMD}"
      ${CMD}
    else
      et-log "Can't start YAAC. Dire Wolf or Bluetooth TNC services not running."
      exit 1
    fi

  else 
    et-log "Error updating configuration. Can't start YAAC"
    exit 1
  fi
}

update-config () {

    [ -z "$ET_USER_CONFIG" ] && ET_USER_CONFIG="${HOME}/.config/emcomm-tools/user.json"

    CALLSIGN=$(cat ${ET_USER_CONFIG} | jq -r .callsign)
    GRID=$(cat ${ET_USER_CONFIG} | jq -r '.grid // empty')

    if [ "${CALLSIGN}" = "N0CALL" ]; then
      notify_user "Can't start YAAC. No callsign set. Run: et-user."
      exit 1
    fi

    # Update station position from grid square
    if [[ -n "$GRID" ]]; then
        update_station_position "$GRID" "$CALLSIGN"
    fi

    et-log "Updating YAAC ports file: ${YAAC_CONF_FILE_PORTS}..."
    cp -v ${YAAC_CONF_FILE_PORTS_TEMPLATE} ${YAAC_CONF_FILE_PORTS}
    sed -i "s|{{ET_CALLSIGN}}|${CALLSIGN}|g" ${YAAC_CONF_FILE_PORTS}

    # Add GPS port only if it is available
    systemctl status gpsd --no-pager > /dev/null
    if [[ $? -ne 0 ]]; then
      et-log "GPS not connected. Removing GPS port from configuration."
      sed -i '/GPSD/d' ${YAAC_CONF_FILE_PORTS}
    fi

    PS_OUT=$(ps -ef | grep "[r]fcomm0")
    if [[ $? -ne 0 ]]; then
      et-log "Bluetooth TNC not connected. Removing rfcomm port from configuration."
      sed -i '/Serial_TNC/d' ${YAAC_CONF_FILE_PORTS}
    fi

    PS_OUT=$(ps -ef | grep "[d]irewolf")
    if [[ $? -ne 0 ]]; then
      et-log "Dire Wolf not running. Removing KISS over TCP port from configuration."
      sed -i '/KISS-over-TCP/d' ${YAAC_CONF_FILE_PORTS}
    fi
    
    echo "Generated the configuration below..."
    echo
    cat ${YAAC_CONF_FILE_PORTS}
    echo
}

case $1 in
  start)
    start
    ;;
  update-config)
    update-config
    ;;
  grid-to-latlon)
    # Test command - convert grid to lat/lon
    if [[ -z "$2" ]]; then
        echo "Usage: $0 grid-to-latlon <grid>"
        echo "Example: $0 grid-to-latlon FN35fl"
        exit 1
    fi
    grid_to_latlon "$2"
    ;;
  *)
    echo "Invalid command."
    usage
    exit 1
  ;;
esac
