#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : January 2026
# Purpose : EmComm-Tools Persistence Manager
#
# Usage   : et-persistence <command> [options]
#
# Commands:
#   detect    - Find persistence drive
#   init      - Initialize new USB for persistence
#   save      - Save configs to USB
#   restore   - Restore configs from USB
#   mount     - Mount/symlink USB data (maps, wikipedia)
#   prepare   - Prepare a Ready Kit USB
#   status    - Show current persistence status
#

set -e

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
VERSION="2.0.0"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

show_banner() {
    echo -e "${BLUE}"
    echo "╔═══════════════════════════════════════════════════════════╗"
    echo "║         EmComm-Tools Persistence Manager v${VERSION}         ║"
    echo "║                   \"Plug and Communicate\"                  ║"
    echo "╚═══════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

show_usage() {
    show_banner
    cat << 'EOF'
Usage: et-persistence <command> [options]

Commands:
  detect              Find EmComm-Tools persistence drive
  init <mount-point>  Initialize USB drive for persistence
  save [--app <name>] Save configurations to USB
  restore [--app <name>] Restore configurations from USB
  mount               Mount/symlink USB data (maps, wikipedia, docs)
  prepare <mount-point> [--quebec|--standard] Prepare Ready Kit USB
  status              Show persistence status and available data

Options:
  -h, --help          Show this help message
  -v, --version       Show version

Examples:
  et-persistence detect
  et-persistence save
  et-persistence restore
  et-persistence init /media/user/VENTOY
  et-persistence prepare /media/user/VENTOY --quebec
  et-persistence status

For more information: https://emcomm-tools.ca
EOF
}

show_status() {
    show_banner
    
    # Try to detect persistence
    local persistence_path=""
    persistence_path=$("${SCRIPT_DIR}/et-persistence-detect" 2>/dev/null) || true
    
    if [[ -n "$persistence_path" ]]; then
        echo -e "${GREEN}✓ Persistence drive found${NC}"
        echo "  Location: ${persistence_path}"
        echo ""
        
        # Show user info
        if [[ -f "${persistence_path}/user.conf" ]]; then
            local callsign=$(jq -r '.callsign // "Not configured"' "${persistence_path}/user.conf")
            local grid=$(jq -r '.grid // "Not set"' "${persistence_path}/user.conf")
            echo "  Callsign: ${callsign}"
            echo "  Grid:     ${grid}"
        fi
        
        # Show last save time
        if [[ -f "${persistence_path}/manifest.json" ]]; then
            local last_save=$(jq -r '.last_save // "Never"' "${persistence_path}/manifest.json")
            echo "  Last saved: ${last_save}"
        fi
        
        echo ""
        
        # Run mount summary if available
        "${SCRIPT_DIR}/et-mount-usb-data" --summary 2>/dev/null || true
        
    else
        echo -e "${YELLOW}⚠ No persistence drive detected${NC}"
        echo ""
        echo "  Insert your EmComm-Tools USB drive, or initialize a new one:"
        echo "    et-persistence init /media/your/usb"
        echo ""
    fi
}

# Main
case "${1:-}" in
    detect)
        shift
        exec "${SCRIPT_DIR}/et-persistence-detect" "$@"
        ;;
    init)
        shift
        exec "${SCRIPT_DIR}/et-persistence-init" "$@"
        ;;
    save)
        shift
        exec "${SCRIPT_DIR}/et-persistence-save" "$@"
        ;;
    restore)
        shift
        exec "${SCRIPT_DIR}/et-persistence-restore" "$@"
        ;;
    mount)
        shift
        exec "${SCRIPT_DIR}/et-mount-usb-data" "$@"
        ;;
    prepare)
        shift
        exec "${SCRIPT_DIR}/et-prepare-ready-kit" "$@"
        ;;
    status)
        show_status
        ;;
    -v|--version)
        echo "et-persistence version ${VERSION}"
        ;;
    -h|--help|"")
        show_usage
        ;;
    *)
        echo -e "${RED}Error: Unknown command '${1}'${NC}"
        echo ""
        show_usage
        exit 1
        ;;
esac
