#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : January 2026
# Purpose : Enable Save & Reboot/Shutdown menu items for USB persistence
#
# This script:
# 1. Copies the .desktop files to /usr/share/applications/
# 2. Hides the default logout menu entry
# 3. Adds our items to XFCE menu layout at bottom
# 4. Refreshes the XFCE panel
#

# Desktop files location (pre-installed in ISO)
DESKTOP_SRC="/opt/emcomm-tools/share/applications"
DESKTOP_DEST="/usr/share/applications"
MENU_FILE="/etc/xdg/menus/xfce-applications.menu"

echo "[SAVE-MENU] Enabling Save & Reboot/Shutdown menu items..."

# 1. Copy desktop files if source exists
if [[ -d "$DESKTOP_SRC" ]]; then
    if [[ -f "${DESKTOP_SRC}/et-save-and-reboot.desktop" ]]; then
        sudo cp -f "${DESKTOP_SRC}/et-save-and-reboot.desktop" "$DESKTOP_DEST/"
        sudo cp -f "${DESKTOP_SRC}/et-save-and-shutdown.desktop" "$DESKTOP_DEST/"
        sudo chmod 644 "$DESKTOP_DEST/et-save-and-reboot.desktop"
        sudo chmod 644 "$DESKTOP_DEST/et-save-and-shutdown.desktop"
        echo "[SAVE-MENU] ✓ Copied desktop files"
    fi
fi

# 2. Hide the default XFCE logout entry
LOGOUT_DESKTOP="${DESKTOP_DEST}/xfce4-session-logout.desktop"
if [[ -f "$LOGOUT_DESKTOP" ]]; then
    if ! grep -q "^NoDisplay=true" "$LOGOUT_DESKTOP"; then
        echo "NoDisplay=true" | sudo tee -a "$LOGOUT_DESKTOP" > /dev/null
        echo "[SAVE-MENU] ✓ Hidden default logout menu"
    else
        echo "[SAVE-MENU] ✓ Logout already hidden"
    fi
fi

# 3. Update XFCE menu layout - add our items at bottom before </Layout>
if [[ -f "$MENU_FILE" ]]; then
    # Remove any existing entries first (avoid duplicates)
    sudo sed -i '/<Filename>et-save-and-reboot.desktop<\/Filename>/d' "$MENU_FILE"
    sudo sed -i '/<Filename>et-save-and-shutdown.desktop<\/Filename>/d' "$MENU_FILE"
    
    # Add entries just before first </Layout> (main menu layout)
    sudo sed -i '0,/<\/Layout>/{s/<\/Layout>/\t\t<Filename>et-save-and-reboot.desktop<\/Filename>\n\t\t<Filename>et-save-and-shutdown.desktop<\/Filename>\n\t<\/Layout>/}' "$MENU_FILE"
    
    echo "[SAVE-MENU] ✓ Added items to menu layout"
fi

# 4. Refresh the XFCE panel (run as user, not root)
if [[ -n "$SUDO_USER" ]]; then
    sudo -u "$SUDO_USER" DISPLAY=:0 xfce4-panel -r 2>/dev/null || true
elif [[ -n "$DISPLAY" ]]; then
    xfce4-panel -r 2>/dev/null || true
fi

echo "[SAVE-MENU] ✓ Done!"
