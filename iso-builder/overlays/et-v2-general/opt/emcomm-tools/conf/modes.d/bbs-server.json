{
    "$schema": "et-mode-v2",
    "id": "bbs-server",
    "name": {
        "en": "BBS Server (LinBPQ)",
        "fr": "Serveur BBS (LinBPQ)"
    },
    "category": "packet",
    "requires": {
        "devices": ["et-audio", "et-cat"],
        "services": ["rigctld"]
    },
    "prechecks": [
        {"type": "device-exists", "path": "/dev/et-audio"},
        {"type": "audio-tagged", "tag": "ET_AUDIO"},
        {"type": "service-active", "name": "rigctld"},
        {"type": "callsign-set"}
    ],
    "config": [
        {
            "template": "conf/template.d/packet/direwolf.simple.conf",
            "target": "conf/packet/direwolf.conf",
            "vars": {
                "ET_CALLSIGN": {"source": "user.json", "key": "callsign"},
                "ET_AUDIO_DEVICE": {"source": "detect-audio", "format": "plughw:{card},{device}"}
            }
        }
    ],
    "pre_start": [
        {"action": "kill-all"},
        {"action": "audio-config"},
        {"action": "bbs-inetd-config"},
        {"action": "bbs-config", "template": "bpq32.simple.cfg"}
    ],
    "chain": [
        {
            "name": "direwolf",
            "command": ["direwolf", "-c", "{direwolf_conf}", "-l", "{log_dir}", "-t", "0", "-p"],
            "health": {"type": "tcp-port", "port": 8001, "timeout": 60},
            "restart": "audio-retry"
        },
        {
            "name": "linbpq",
            "command": ["xfce4-terminal", "--title=LinBPQ BBS Server", "--working-directory={bbs_server_dir}", "-e", "linbpq"],
            "cwd": "~/.local/share/emcomm-tools/bbs-server",
            "health": {},
            "restart": "never",
            "depends_on": "direwolf"
        }
    ],
    "post_start": [],
    "kill_all_first": true
}
