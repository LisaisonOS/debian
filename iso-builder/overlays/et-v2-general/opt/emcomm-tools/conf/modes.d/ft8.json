{
    "$schema": "et-mode-v2",
    "id": "ft8",
    "name": {
        "en": "FT8/FT4 (WSJT-X)",
        "fr": "FT8/FT4 (WSJT-X)"
    },
    "category": "digital",
    "requires": {
        "devices": ["et-audio", "et-cat"],
        "services": ["rigctld"]
    },
    "prechecks": [
        {"type": "device-exists", "path": "/dev/et-audio"},
        {"type": "audio-tagged", "tag": "ET_AUDIO"},
        {"type": "service-active", "name": "rigctld"},
        {"type": "callsign-set"}
    ],
    "config": [
        {
            "type": "ini-update",
            "target": "~/.config/WSJT-X.ini",
            "updates": [
                {"key": "MyCall", "source": "user.json", "field": "callsign"},
                {"key": "MyGrid", "source": "detect-grid"},
                {"key": "Rig", "value": "Hamlib NET rigctl"},
                {"key": "CATNetworkPort", "value": "localhost:4532"},
                {"key": "SoundInName", "value": "\"sysdefault:CARD=ET_AUDIO\""},
                {"key": "SoundOutName", "value": "\"sysdefault:CARD=ET_AUDIO\""},
                {"key": "SaveDir", "source": "detect-savedir", "field": "WSJT-X/save"},
                {"key": "AzElDir", "source": "detect-savedir", "field": "WSJT-X"}
            ]
        }
    ],
    "pre_start": [
        {"action": "kill-all"},
        {"action": "audio-config"},
        {"action": "prime-rigctld"},
        {"action": "wait-audio", "seconds": 3},
        {"action": "qsy-band", "frequencies": {
            "160m": 1840000,
            "80m": 3573000,
            "40m": 7074000,
            "30m": 10136000,
            "20m": 14074000,
            "17m": 18100000,
            "15m": 21074000,
            "12m": 24915000,
            "10m": 28074000
        }}
    ],
    "chain": [
        {
            "name": "wsjtx",
            "command": ["/usr/bin/wsjtx"],
            "health": {},
            "restart": "never"
        }
    ],
    "post_start": [],
    "kill_all_first": true
}
