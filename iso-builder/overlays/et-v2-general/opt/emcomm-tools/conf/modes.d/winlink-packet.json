{
    "$schema": "et-mode-v2",
    "id": "winlink-packet",
    "name": {
        "en": "Winlink VHF/UHF Packet",
        "fr": "Winlink Paquet VHF/UHF"
    },
    "category": "winlink",
    "requires_bands": ["VHF", "UHF"],
    "requires": {
        "devices": ["et-audio", "et-cat"],
        "services": ["rigctld"]
    },
    "prechecks": [
        {"type": "device-exists", "path": "/dev/et-audio"},
        {"type": "audio-tagged", "tag": "ET_AUDIO"},
        {"type": "service-active", "name": "rigctld"},
        {"type": "callsign-set"}
    ],
    "config": [
        {
            "template": "conf/template.d/packet/direwolf.simple.conf",
            "target": "conf/packet/direwolf.conf",
            "vars": {
                "ET_CALLSIGN": {"source": "user.json", "key": "callsign"},
                "ET_AUDIO_DEVICE": {"source": "detect-audio", "format": "plughw:{card},{device}"}
            }
        }
    ],
    "pre_start": [
        {"action": "kill-all"},
        {"action": "audio-config"},
        {"action": "pat-config", "template": "config.ax25-agw.json"}
    ],
    "chain": [
        {
            "name": "direwolf",
            "command": ["direwolf", "-c", "{direwolf_conf}", "-l", "{log_dir}", "-t", "0", "-p"],
            "health": {"type": "tcp-port", "port": 8001, "timeout": 60},
            "restart": "audio-retry"
        },
        {
            "name": "pat-http",
            "command": ["pat", "http"],
            "health": {"type": "tcp-port", "port": 8080, "timeout": 60},
            "restart": "never",
            "depends_on": "direwolf"
        }
    ],
    "post_start": [
        {"action": "open-browser", "url": "http://localhost:8080"}
    ],
    "kill_all_first": true
}
