{
    "$schema": "et-mode-v2",
    "id": "winlink-vara-fm",
    "name": {
        "en": "Winlink VHF/UHF (VARA FM)",
        "fr": "Winlink VHF/UHF (VARA FM)"
    },
    "category": "winlink",
    "requires_bands": [
        "VHF",
        "UHF"
    ],
    "requires": {
        "devices": [
            "et-audio",
            "et-cat"
        ],
        "services": []
    },
    "prechecks": [
        {
            "type": "device-exists",
            "path": "/dev/et-audio"
        },
        {
            "type": "audio-tagged",
            "tag": "ET_AUDIO"
        },
        {
            "type": "callsign-set"
        }
    ],
    "config": [],
    "pre_start": [
        {
            "action": "kill-all"
        },
        {
            "action": "audio-config"
        },
        {
            "action": "vara-fm-ptt-config"
        },
        {
            "action": "pat-config",
            "template": "config.vara-fm.json"
        }
    ],
    "chain": [
        {
            "name": "vara-fm",
            "command": [
                "wine",
                "C:\\VARA FM\\VARAFM.exe"
            ],
            "env": {
                "WINEPREFIX": "~/.wine32",
                "WINEARCH": "win32"
            },
            "cwd": "~/.wine32/drive_c/VARA FM",
            "health": {
                "type": "tcp-port",
                "port": 8300,
                "timeout": 60
            },
            "restart": "never"
        },
        {
            "name": "pat-http",
            "command": [
                "pat",
                "http"
            ],
            "health": {
                "type": "tcp-port",
                "port": 8080,
                "timeout": 60
            },
            "restart": "never",
            "depends_on": "vara-fm"
        }
    ],
    "post_start": [
        {
            "action": "open-browser",
            "url": "http://localhost:8080/ui?mode=varafm&band={auto-band}#"
        }
    ],
    "kill_all_first": true
}
