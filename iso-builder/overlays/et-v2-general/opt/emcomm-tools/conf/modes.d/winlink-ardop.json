{
    "$schema": "et-mode-v2",
    "id": "winlink-ardop",
    "name": {
        "en": "Winlink HF (ARDOP)",
        "fr": "Winlink HF (ARDOP)"
    },
    "category": "winlink",
    "requires": {
        "devices": ["et-audio", "et-cat"],
        "services": ["rigctld"]
    },
    "prechecks": [
        {"type": "device-exists", "path": "/dev/et-audio"},
        {"type": "audio-tagged", "tag": "ET_AUDIO"},
        {"type": "service-active", "name": "rigctld"},
        {"type": "callsign-set"}
    ],
    "config": [],
    "pre_start": [
        {"action": "kill-all"},
        {"action": "audio-config"},
        {"action": "pat-config", "template": "config.ardop.json"}
    ],
    "chain": [
        {
            "name": "ardopcf",
            "command": ["ardopcf", "8515", "{audio_device}", "{audio_device}", "--logdir", "{log_dir}"],
            "health": {"type": "tcp-port", "port": 8515, "timeout": 60},
            "restart": "audio-retry"
        },
        {
            "name": "pat-http",
            "command": ["pat", "http"],
            "health": {"type": "tcp-port", "port": 8080, "timeout": 60},
            "restart": "never",
            "depends_on": "ardopcf"
        }
    ],
    "post_start": [
        {"action": "open-browser", "url": "http://localhost:8080/ui?mode=ardop&band={auto-band}#"}
    ],
    "kill_all_first": true
}
