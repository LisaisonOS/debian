{
    "$schema": "et-mode-v2",
    "id": "fldigi",
    "name": {
        "en": "fldigi",
        "fr": "fldigi"
    },
    "category": "digital",
    "requires": {
        "devices": ["et-audio", "et-cat"],
        "services": ["rigctld"]
    },
    "prechecks": [
        {"type": "device-exists", "path": "/dev/et-audio"},
        {"type": "audio-tagged", "tag": "ET_AUDIO"},
        {"type": "service-active", "name": "rigctld"},
        {"type": "callsign-set"}
    ],
    "config": [
        {
            "type": "xml-update",
            "target": "~/.fldigi/fldigi_def.xml",
            "updates": [
                {"tag": "MYCALL", "source": "user.json", "field": "callsign"},
                {"tag": "MYLOC", "source": "detect-grid"},
                {"tag": "AUDIOIO", "value": "1"},
                {"tag": "PORTINDEVICE", "source": "detect-portaudio", "field": "device"},
                {"tag": "PORTININDEX", "source": "detect-portaudio", "field": "index"},
                {"tag": "PORTOUTDEVICE", "source": "detect-portaudio", "field": "device"},
                {"tag": "PORTOUTINDEX", "source": "detect-portaudio", "field": "index"},
                {"tag": "CHKUSEHAMLIBIS", "value": "1"},
                {"tag": "HAMRIGMODEL", "value": "2"},
                {"tag": "HAMLIBCMDPTT", "value": "1"},
                {"tag": "HAMRIGDEVICE", "value": "localhost:4532"},
                {"tag": "RECEIVERSID", "value": "1"},
                {"tag": "TRANSMITRSID", "value": "1"},
                {"tag": "MT63INTEGRATION", "value": "1"},
                {"tag": "PRETONE", "value": "2"},
                {"tag": "OPEN_NBEMS_FOLDER", "value": "1"},
                {"tag": "FLMSG_PATHNAME", "value": "/usr/local/bin/flmsg"}
            ]
        }
    ],
    "pre_start": [
        {"action": "kill-all"},
        {"action": "audio-config"}
    ],
    "chain": [
        {
            "name": "fldigi",
            "command": ["/usr/bin/fldigi"],
            "health": {},
            "restart": "never"
        }
    ],
    "post_start": [],
    "kill_all_first": true
}
