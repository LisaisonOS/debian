{
    "$schema": "et-mode-v2",
    "id": "winlink-vara-hf",
    "name": {
        "en": "Winlink HF (VARA)",
        "fr": "Winlink HF (VARA)"
    },
    "category": "winlink",
    "requires": {
        "devices": ["et-audio", "et-cat"],
        "services": ["rigctld"]
    },
    "prechecks": [
        {"type": "device-exists", "path": "/dev/et-audio"},
        {"type": "audio-tagged", "tag": "ET_AUDIO"},
        {"type": "service-active", "name": "rigctld"},
        {"type": "callsign-set"}
    ],
    "config": [],
    "pre_start": [
        {"action": "kill-all"},
        {"action": "audio-config"},
        {"action": "pat-config", "template": "config.vara-hf.json"}
    ],
    "chain": [
        {
            "name": "vara-hf",
            "command": ["wine", "C:\\VARA\\VARA.exe"],
            "env": {
                "WINEPREFIX": "~/.wine32",
                "WINEARCH": "win32"
            },
            "cwd": "~/.wine32/drive_c/VARA",
            "health": {"type": "tcp-port", "port": 8300, "timeout": 60},
            "restart": "never"
        },
        {
            "name": "pat-http",
            "command": ["pat", "http"],
            "health": {"type": "tcp-port", "port": 8080, "timeout": 60},
            "restart": "never",
            "depends_on": "vara-hf"
        }
    ],
    "post_start": [
        {"action": "open-browser", "url": "http://localhost:8080/ui?mode=varahf&band={auto-band}#"}
    ],
    "kill_all_first": true
}
