{
    "$schema": "et-mode-v2",
    "id": "bbs-client-paracon",
    "name": {
        "en": "BBS Client (Paracon)",
        "fr": "Client BBS (Paracon)"
    },
    "category": "packet",
    "requires": {
        "devices": ["et-audio", "et-cat"],
        "services": ["rigctld"]
    },
    "prechecks": [
        {"type": "device-exists", "path": "/dev/et-audio"},
        {"type": "audio-tagged", "tag": "ET_AUDIO"},
        {"type": "service-active", "name": "rigctld"},
        {"type": "callsign-set"}
    ],
    "config": [
        {
            "template": "conf/template.d/packet/direwolf.simple.conf",
            "target": "conf/packet/direwolf.conf",
            "vars": {
                "ET_CALLSIGN": {"source": "user.json", "key": "callsign"},
                "ET_AUDIO_DEVICE": {"source": "detect-audio", "format": "plughw:{card},{device}"}
            }
        }
    ],
    "pre_start": [
        {"action": "kill-all"},
        {"action": "audio-config"},
        {"action": "paracon-config"}
    ],
    "chain": [
        {
            "name": "direwolf",
            "command": ["direwolf", "-c", "{direwolf_conf}", "-l", "{log_dir}", "-t", "0", "-p"],
            "health": {"type": "tcp-port", "port": 8001, "timeout": 60},
            "restart": "audio-retry"
        },
        {
            "name": "paracon",
            "command": ["xfce4-terminal", "--title=Paracon BBS Client", "--working-directory={bbs_client_dir}", "-e", "paracon"],
            "health": {},
            "restart": "never",
            "depends_on": "direwolf"
        }
    ],
    "post_start": [],
    "kill_all_first": true
}
