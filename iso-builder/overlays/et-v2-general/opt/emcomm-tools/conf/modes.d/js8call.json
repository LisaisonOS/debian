{
    "$schema": "et-mode-v2",
    "id": "js8call",
    "name": {
        "en": "JS8Call",
        "fr": "JS8Call"
    },
    "category": "digital",
    "requires": {
        "devices": ["et-audio", "et-cat"],
        "services": ["rigctld"]
    },
    "prechecks": [
        {"type": "device-exists", "path": "/dev/et-audio"},
        {"type": "audio-tagged", "tag": "ET_AUDIO"},
        {"type": "service-active", "name": "rigctld"},
        {"type": "callsign-set"}
    ],
    "config": [
        {
            "type": "ini-update",
            "target": "~/.config/JS8Call.ini",
            "updates": [
                {"key": "MyCall", "source": "user.json", "field": "callsign"},
                {"key": "MyGrid", "source": "detect-grid"},
                {"key": "MyInfo", "source": "radio-model-safe", "mode": "replace-first-word"},
                {"key": "SoundInName", "value": "\"sysdefault:CARD=ET_AUDIO\""},
                {"key": "SoundOutName", "value": "\"sysdefault:CARD=ET_AUDIO\""},
                {"key": "NotificationSoundOutName", "value": "\"sysdefault:CARD=PCH\""},
                {"key": "AzElDir", "source": "detect-savedir", "field": "JS8Call"},
                {"key": "SaveDir", "source": "detect-savedir", "field": "JS8Call/save"},
                {"key": "MRUdir", "source": "detect-savedir", "field": "JS8Call/save"}
            ]
        }
    ],
    "pre_start": [
        {"action": "kill-all"},
        {"action": "audio-config"},
        {"action": "prime-rigctld"},
        {"action": "qsy-band", "frequencies": {
            "160m": 1842000,
            "80m": 3578000,
            "40m": 7078000,
            "30m": 10130000,
            "20m": 14078000,
            "17m": 18104000,
            "15m": 21078000,
            "12m": 24922000,
            "10m": 28078000
        }},
        {"action": "js8spotter-setup"}
    ],
    "chain": [
        {
            "name": "js8call",
            "command": ["/usr/bin/js8call"],
            "health": {"type": "tcp-port", "port": 2442, "timeout": 60},
            "restart": "never"
        }
    ],
    "post_start": [
        {"action": "launch-js8spotter"}
    ],
    "kill_all_first": true
}
