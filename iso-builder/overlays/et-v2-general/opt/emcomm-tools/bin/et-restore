#!/bin/bash
# =============================================================================
# et-restore - EmComm-Tools Backup Restore System
# Version: 1.0.0
# Updated: 2026-01-10
# Author: Sylvain Deguire (VA2OPS)
#
# Restore files from backup after failed or unwanted update
# =============================================================================

set -e

# Paths
ET_HOME="/opt/emcomm-tools"
ET_BACKUP_DIR="${ET_HOME}/backup"
ET_LOG_FILE="/var/log/emcomm-tools/restore.log"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() {
    local level="$1"
    shift
    local message="$*"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    case "$level" in
        INFO)  echo -e "${GREEN}[INFO]${NC} $message" ;;
        WARN)  echo -e "${YELLOW}[WARN]${NC} $message" ;;
        ERROR) echo -e "${RED}[ERROR]${NC} $message" ;;
    esac
    
    mkdir -p "$(dirname "$ET_LOG_FILE")"
    echo "[$timestamp] [$level] $message" >> "$ET_LOG_FILE"
}

list_backups() {
    echo "╔══════════════════════════════════════════════════════════════════╗"
    echo "║  Available Backups                                               ║"
    echo "╠══════════════════════════════════════════════════════════════════╣"
    
    if [ ! -d "$ET_BACKUP_DIR" ]; then
        echo "║  No backups found                                                ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        return
    fi
    
    local i=1
    for backup in $(ls -dt "${ET_BACKUP_DIR}"/*/ 2>/dev/null); do
        local backup_name=$(basename "$backup")
        local file_count=$(find "$backup" -type f | wc -l)
        printf "║  %d) %-20s (%d files)                              ║\n" "$i" "$backup_name" "$file_count"
        ((i++))
    done
    
    if [ $i -eq 1 ]; then
        echo "║  No backups found                                                ║"
    fi
    
    echo "╚══════════════════════════════════════════════════════════════════╝"
}

show_backup_contents() {
    local backup_path="$1"
    
    echo ""
    echo "Files in backup:"
    echo "────────────────"
    find "$backup_path" -type f | while read file; do
        local rel_path="${file#$backup_path/}"
        echo "  $rel_path"
    done
    echo ""
}

restore_backup() {
    local backup_name="$1"
    local backup_path="${ET_BACKUP_DIR}/${backup_name}"
    
    if [ ! -d "$backup_path" ]; then
        log ERROR "Backup not found: $backup_name"
        return 1
    fi
    
    log INFO "Restoring from backup: $backup_name"
    
    show_backup_contents "$backup_path"
    
    read -p "Restore these files? (y/N): " confirm
    if [ "${confirm,,}" != "y" ]; then
        log INFO "Restore cancelled by user"
        return 0
    fi
    
    local failed=false
    
    find "$backup_path" -type f | while read backup_file; do
        local rel_path="${backup_file#$backup_path/}"
        local dest_file="${ET_HOME}/${rel_path}"
        
        log INFO "Restoring: $rel_path"
        
        mkdir -p "$(dirname "$dest_file")"
        
        if ! cp -p "$backup_file" "$dest_file"; then
            log ERROR "Failed to restore: $rel_path"
            failed=true
        fi
    done
    
    if [ "$failed" == "true" ]; then
        log ERROR "Some files failed to restore"
        return 1
    fi
    
    log INFO "Restore complete!"
}

restore_last() {
    local last_backup=$(ls -dt "${ET_BACKUP_DIR}"/*/ 2>/dev/null | head -1)
    
    if [ -z "$last_backup" ]; then
        log ERROR "No backups available"
        return 1
    fi
    
    local backup_name=$(basename "$last_backup")
    restore_backup "$backup_name"
}

restore_file() {
    local file_path="$1"
    local backup_name="$2"
    
    local backup_file="${ET_BACKUP_DIR}/${backup_name}/${file_path}"
    local dest_file="${ET_HOME}/${file_path}"
    
    if [ ! -f "$backup_file" ]; then
        log ERROR "File not found in backup: $file_path"
        return 1
    fi
    
    log INFO "Restoring: $file_path from $backup_name"
    
    mkdir -p "$(dirname "$dest_file")"
    
    if ! cp -p "$backup_file" "$dest_file"; then
        log ERROR "Failed to restore: $file_path"
        return 1
    fi
    
    log INFO "File restored successfully"
}

show_help() {
    cat << EOF
EmComm-Tools Restore System

Usage: et-restore [OPTIONS] [BACKUP_NAME]

Commands:
  (none)           List available backups
  BACKUP_NAME      Restore specific backup (e.g., 2026-01-10_143022)
  --last           Restore most recent backup
  --file PATH      Restore specific file from backup

Options:
  -h, --help       Show this help message

Examples:
  et-restore                           # List backups
  et-restore 2026-01-10_143022         # Restore specific backup
  et-restore --last                    # Restore most recent backup
  et-restore --file bin/et-dashboard 2026-01-10_143022

EOF
}

# =============================================================================
# Main
# =============================================================================
main() {
    if [ $# -eq 0 ]; then
        list_backups
        exit 0
    fi
    
    case $1 in
        -h|--help)
            show_help
            ;;
        --last)
            restore_last
            ;;
        --file)
            if [ -z "$2" ] || [ -z "$3" ]; then
                log ERROR "Usage: et-restore --file PATH BACKUP_NAME"
                exit 1
            fi
            restore_file "$2" "$3"
            ;;
        *)
            restore_backup "$1"
            ;;
    esac
}

main "$@"
