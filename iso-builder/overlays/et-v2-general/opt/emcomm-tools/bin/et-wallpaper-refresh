#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : March 2026
# Purpose : Force XFCE to re-render wallpaper after display scaling is applied.
#           On HiDPI screens (scale 2.5, 1.25, etc.), xfdesktop renders the
#           wallpaper before scaling kicks in, showing only the top-left portion.
#           Toggling the image-style property forces a correct re-render.

# Wait for XFCE desktop to be fully loaded with scaling applied
sleep 8

# Toggle image-style: set to Scaled (4), then back to Zoomed (5).
# This forces xfdesktop to re-render the wallpaper at the correct
# scaled resolution, fixing the HiDPI crop/stretch issue.
for prop in $(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep image-style); do
    xfconf-query -c xfce4-desktop -p "$prop" -s 4 2>/dev/null
done

sleep 1

for prop in $(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep image-style); do
    xfconf-query -c xfce4-desktop -p "$prop" -s 5 2>/dev/null
done
