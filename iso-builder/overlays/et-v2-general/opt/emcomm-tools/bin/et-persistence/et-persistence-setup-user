#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : January 2026
# Updated : January 2026 - Removed 15-min timer (bad for emergency/battery use)
# Purpose : One-time user setup for persistence
#
# Save happens on SHUTDOWN only via system service emcomm-persistence-save.service
#

SETUP_FLAG="${HOME}/.config/emcomm-tools/.persistence-setup-complete"

# Only run once
if [[ -f "$SETUP_FLAG" ]]; then
    exit 0
fi

# Check if we're in a live session with USB persistence
if /opt/emcomm-tools/bin/et-persistence/et-persistence-detect &>/dev/null; then
    # Show notification that persistence is active
    if command -v notify-send &>/dev/null; then
        notify-send -i drive-removable-media \
            "EmComm-Tools" \
            "USB persistence detected. Your config will be saved on shutdown."
    fi
fi

# Mark as complete
mkdir -p "$(dirname "$SETUP_FLAG")"
touch "$SETUP_FLAG"
