# Download map tiles (Quebec Edition)
download_quebec_maps() {
    local base="$1"
    
    log "Downloading Quebec Edition maps..."
    
    local TTP_BASE="https://github.com/thetechprepper/emcomm-tools-os-community/releases/download"
    local RELEASE="emcomm-tools-os-community-20251128-r5-final-5.0.0"
    
    # MBTiles
    local MBTILES=(
        "osm-world-zoom0to7-20251121.mbtiles"
        "osm-ca-zoom0to10-20251120.mbtiles"
        "osm-us-zoom0to11-20251120.mbtiles"
    )
    
    for file in "${MBTILES[@]}"; do
        local dest="${base}/maps/mbtiles/${file}"
        local dest_legacy="${base}/tilesets/${file}"
        
        if [[ -f "$dest" ]]; then
            log "${file} already exists, skipping."
            continue
        fi
        
        log "Downloading ${file}..."
        if curl -L -f -o "$dest" "${TTP_BASE}/${RELEASE}/${file}"; then
            # Create symlink in legacy location
            ln -sf "../maps/mbtiles/${file}" "$dest_legacy" 2>/dev/null || true
            log "Downloaded: ${file}"
        else
            log "WARNING: Failed to download ${file}"
        fi
    done
    
    # Navit maps from Geofabrik
    local GEOFABRIK="https://download.geofabrik.de/north-america/canada"
    local REGIONS=("quebec" "ontario")
    
    for region in "${REGIONS[@]}"; do
        local pbf_file="${region}-latest.osm.pbf"
        local bin_file="${region}-latest.osm.bin"
        local dest_bin="${base}/maps/navit/${bin_file}"
        local dest_pbf="${base}/my-maps/${pbf_file}"
        
        if [[ -f "$dest_bin" ]] || [[ -f "$dest_pbf" ]]; then
            log "${region} map already exists, skipping."
            continue
        fi
        
        log "Downloading ${pbf_file}..."
        if curl -L -f -o "/tmp/${pbf_file}" "${GEOFABRIK}/${pbf_file}"; then
            # Convert to Navit format if maptool available
            if command -v maptool &>/dev/null; then
                log "Converting ${region} to Navit format..."
                maptool --protobuf -i "/tmp/${pbf_file}" "$dest_bin"
                rm "/tmp/${pbf_file}"
            else
                log "maptool not found, keeping .pbf format"
                mv "/tmp/${pbf_file}" "$dest_pbf"
            fi
            log "Downloaded: ${region}"
        else
            log "WARNING: Failed to download ${region}"
        fi
    done
    
    log "Quebec Edition maps complete!"
}

# Download Wikipedia (Quebec = French, Standard = English)
download_wikipedia() {
    local base="$1"
    local edition="$2"
    
    log "Downloading Wikipedia for ${edition} edition..."
    
    # Note: These URLs change frequently, may need manual update
    local KIWIX_BASE="https://download.kiwix.org/zim/wikipedia"
    
    # List current files
    log "Checking available Wikipedia files..."
    log "Visit: ${KIWIX_BASE}"
    log ""
    log "For Quebec Edition, download French Wikipedia:"
    log "  wikipedia_fr_all_maxi_*.zim"
    log ""
    log "For Standard Edition, download English subsets:"
    log "  wikipedia_en_medicine_*.zim"
    log "  wikipedia_en_simple_all_*.zim"
    log ""
    log "Place downloaded .zim files in: ${base}/wikipedia/"
}

# Show summary
show_summary() {
    local base="$1"
    
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  Ready Kit USB Summary"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    
    # Calculate sizes
    for dir in "emcomm-data" "maps" "tilesets" "my-maps" "wikipedia" "docs"; do
        if [[ -d "${base}/${dir}" ]]; then
            local size=$(du -sh "${base}/${dir}" 2>/dev/null | cut -f1)
            local count=$(find "${base}/${dir}" -type f 2>/dev/null | wc -l)
            printf "  %-15s %8s  (%d files)\n" "${dir}/" "$size" "$count"
        fi
    done
    
    echo ""
    echo "───────────────────────────────────────────────────────────────"
    local total=$(du -sh "$base" 2>/dev/null | cut -f1)
    printf "  %-15s %8s\n" "TOTAL" "$total"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    
    # Check what's missing
    echo "Checklist:"
    [[ -f "${base}/emcomm-data/user.json" ]] && echo "  ✓ emcomm-data structure" || echo "  ✗ emcomm-data structure"
    [[ -d "${base}/maps/mbtiles" ]] && [[ -n "$(ls -A ${base}/maps/mbtiles 2>/dev/null)" ]] && echo "  ✓ Map tiles" || echo "  ✗ Map tiles (empty)"
    [[ -d "${base}/wikipedia" ]] && [[ -n "$(ls -A ${base}/wikipedia/*.zim 2>/dev/null)" ]] && echo "  ✓ Wikipedia ZIM" || echo "  ✗ Wikipedia ZIM (empty)"
    [[ -n "$(ls ${base}/*.iso 2>/dev/null)" ]] && echo "  ✓ ISO image" || echo "  ✗ ISO image (copy emcomm-tools-*.iso here!)"
    echo ""
}

# Main
main() {
    local mount_point=""
    local edition="standard"
    local structure_only=false
    local download_maps=false
    local download_wiki=false
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                show_usage
                exit 0
                ;;
            --quebec)
                edition="quebec"
                download_maps=true
                download_wiki=true
                shift
                ;;
            --standard)
                edition="standard"
                download_maps=true
                download_wiki=true
                shift
                ;;
            --structure-only)
                structure_only=true
                shift
                ;;
            --download-maps)
                download_maps=true
                shift
                ;;
            --download-wiki)
                download_wiki=true
                shift
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                mount_point="$1"
                shift
                ;;
        esac
    done
    
    # Validate
    if [[ -z "$mount_point" ]]; then
        show_usage
        exit 1
    fi
    
    if [[ ! -d "$mount_point" ]]; then
        error "Mount point does not exist: ${mount_point}"
    fi
    
    if [[ ! -w "$mount_point" ]]; then
        error "Mount point is not writable: ${mount_point}"
    fi
    
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  LiaisonOS Ready Kit Preparation"
    echo "  Version ${VERSION}"
    echo "═══════════════════════════════════════════════════════════════"
    echo "  Target:  ${mount_point}"
    echo "  Edition: ${edition^}"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    
    # Create all directory structures
    create_emcomm_data "$mount_point"
    create_maps_structure "$mount_point"
    create_wikipedia_structure "$mount_point"
    create_docs_structure "$mount_point"
    create_main_readme "$mount_point" "$edition"
    
    if [[ "$structure_only" == "true" ]]; then
        log "Structure-only mode, skipping downloads."
    else
        # Download content
        if [[ "$download_maps" == "true" ]]; then
            download_quebec_maps "$mount_point"
        fi
        
        if [[ "$download_wiki" == "true" ]]; then
            download_wikipedia "$mount_point" "$edition"
        fi
    fi
    
    # Show summary
    show_summary "$mount_point"
    
    echo "═══════════════════════════════════════════════════════════════"
    echo "  NEXT STEPS:"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    echo "  1. Copy ISO image:"
    echo "     cp emcomm-tools-2.0.iso ${mount_point}/"
    echo ""
    echo "  2. Download Wikipedia ZIM files (if not done):"
    echo "     Visit: https://download.kiwix.org/zim/wikipedia/"
    echo "     Copy to: ${mount_point}/wikipedia/"
    echo ""
    echo "  3. Test boot and verify everything works"
    echo ""
    echo "  4. Ready to sell! 🚀"
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    
    log "Ready Kit preparation complete!"
}

main "$@"
