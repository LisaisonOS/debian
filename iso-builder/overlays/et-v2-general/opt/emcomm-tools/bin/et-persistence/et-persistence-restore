# --- Navit (config and bookmarks) ---
NAVIT_CONF_DIR="${HOME}/.navit"
if [[ -d "${PERSISTENCE_PATH}/configs/navit" ]]; then
    mkdir -p "$NAVIT_CONF_DIR"
    # Restore navit.xml config
    [[ -f "${PERSISTENCE_PATH}/configs/navit/navit.xml" ]] && cp "${PERSISTENCE_PATH}/configs/navit/navit.xml" "$NAVIT_CONF_DIR/"
    # Restore bookmarks
    [[ -f "${PERSISTENCE_PATH}/configs/navit/bookmark.txt" ]] && cp "${PERSISTENCE_PATH}/configs/navit/bookmark.txt" "$NAVIT_CONF_DIR/"
    # Restore destination history
    [[ -f "${PERSISTENCE_PATH}/configs/navit/destination.txt" ]] && cp "${PERSISTENCE_PATH}/configs/navit/destination.txt" "$NAVIT_CONF_DIR/"
    log "✓ Restored: Navit config"
    ((RESTORED++)) || true
else
    log "⏭ Skip: Navit (not found on USB)"
fi

# --- Firefox ---
log "Starting Firefox restore..."
if restore_firefox_profile; then
    ((RESTORED++)) || true
fi

# --- WiFi Networks (NetworkManager) - LIVE MODE ONLY ---
log "Starting WiFi restore..."
WIFI_SRC="${PERSISTENCE_PATH}/configs/wifi"
WIFI_DEST="/etc/NetworkManager/system-connections"
if [[ -d "$WIFI_SRC" ]] && [[ -n "$(ls -A "$WIFI_SRC" 2>/dev/null)" ]]; then
    WIFI_COUNT=$(ls -1 "$WIFI_SRC" 2>/dev/null | wc -l)

    # Copy and strip interface-name (hardware-specific) for portability
    for wifi_file in "$WIFI_SRC"/*; do
        if [[ -f "$wifi_file" ]]; then
            filename=$(basename "$wifi_file")
            conn_id=$(grep "^id=" "$wifi_file" | cut -d= -f2)
            log "WiFi restore: processing $filename (id=$conn_id)"

            # Delete any existing connections with same base name (avoid "Sergent_971 1" duplicates)
            if [[ -n "$conn_id" ]]; then
                sudo rm -f "$WIFI_DEST/${conn_id}"*.nmconnection 2>/dev/null
            fi

            # Copy without interface-name line
            grep -v "^interface-name=" "$wifi_file" | sudo tee "$WIFI_DEST/$filename" > /dev/null
        fi
    done
    # Fix permissions (NetworkManager requires 600)
    sudo chmod 600 "$WIFI_DEST"/*.nmconnection 2>/dev/null
    sudo chown root:root "$WIFI_DEST"/*.nmconnection 2>/dev/null
    # Restart NetworkManager to pick up new files
    sudo systemctl restart NetworkManager 2>/dev/null
    sleep 2
    # Load and try to connect each network
    for wifi_file in "$WIFI_DEST"/*.nmconnection; do
        sudo nmcli connection load "$wifi_file" 2>/dev/null || true
        # Try to bring up the connection (uses id= from file)
        conn_id=$(sudo grep "^id=" "$wifi_file" 2>/dev/null | cut -d= -f2)
        if [[ -n "$conn_id" ]]; then
            sudo nmcli connection up "$conn_id" 2>/dev/null || true
        fi
    done
    log "✓ Restored: WiFi networks ($WIFI_COUNT connections)"
    ((RESTORED++)) || true
else
    log "⏭ Skip: WiFi (no saved networks)"
fi

# --- Bluetooth Pairings - LIVE MODE ONLY ---
log "Starting Bluetooth restore..."
BT_TAR="${PERSISTENCE_PATH}/configs/bluetooth/bt-pairings.tar"
BT_DEST="/var/lib/bluetooth"
if [[ -f "$BT_TAR" ]]; then
    # Recreate dir — on live systems, overlay lower layer dir is read-only
    sudo rm -rf "$BT_DEST"
    sudo mkdir -p "$BT_DEST"
    sudo tar xf "$BT_TAR" -C "$BT_DEST" 2>/dev/null
    sudo chown -R root:bluetooth "$BT_DEST/" 2>/dev/null
    sudo chmod -R 700 "$BT_DEST/" 2>/dev/null
    # Restart bluetooth service to load restored pairings
    sudo systemctl restart bluetooth 2>/dev/null
    sleep 2
    BT_COUNT=$(sudo find "$BT_DEST" -mindepth 2 -maxdepth 2 -type d 2>/dev/null | wc -l)
    log "✓ Restored: Bluetooth pairings ($BT_COUNT devices)"
    ((RESTORED++)) || true
else
    log "⏭ Skip: Bluetooth (no saved pairings)"
fi

# --- Thunderbird (can be large, compressed) ---
log "Starting Thunderbird restore..."
if restore_thunderbird_profile; then
    ((RESTORED++)) || true
fi

# --- Documents & Downloads ---
log "Starting Documents & Downloads restore..."
for user_dir in "Documents" "Downloads"; do
    src_dir="${PERSISTENCE_PATH}/user-data/${user_dir,,}"
    dest_dir="${HOME}/${user_dir}"

    if [[ ! -d "$src_dir" ]] || [[ -z "$(ls -A "$src_dir" 2>/dev/null)" ]]; then
        log "⏭ Skip: ${user_dir} (not found on USB)"
        continue
    fi

    mkdir -p "$dest_dir"

    # Sync with rsync (no --delete on restore — merge, don't remove local files)
    if command -v rsync &>/dev/null; then
        rsync -r --times "$src_dir/" "$dest_dir/" 2>/dev/null
    else
        # Fallback: cp -ru (copy only newer files)
        cp -ru "$src_dir/"* "$dest_dir/" 2>/dev/null || true
    fi

    file_count=$(find "$dest_dir" -type f 2>/dev/null | wc -l)
    log "✓ Restored: ${user_dir} (${file_count} files)"
    ((RESTORED++)) || true
done

