#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : January 2026
# Purpose : Restore EmComm-Tools configs from USB persistence
#

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

# Detect persistence location FIRST (needed for log file)
PERSISTENCE_PATH=$("${SCRIPT_DIR}/et-persistence-detect" 2>/dev/null) || true

# Setup logging to file
LOG_FILE=""
if [[ -n "$PERSISTENCE_PATH" ]]; then
    LOG_FILE="${PERSISTENCE_PATH}/restore.log"
fi

log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    # Always write to log file if available
    if [[ -n "$LOG_FILE" ]]; then
        echo "$msg" >> "$LOG_FILE"
    fi
    # Always write to console for restore
    echo "$msg"
}

error() {
    log "ERROR: $1"
    exit 1
}

# Start logging
log "========================================"
log "RESTORE STARTED"
log "User: $(whoami)"
log "HOME: $HOME"
log "PWD: $(pwd)"
log "Args: $*"
log "========================================"

# Check if running in live boot mode
is_live_boot() {
    # Debian live creates /run/live
    [[ -d /run/live ]] && return 0
    # Alternative: check if root is overlay/tmpfs
    grep -q 'overlay / ' /proc/mounts 2>/dev/null && return 0
    grep -q 'tmpfs / ' /proc/mounts 2>/dev/null && return 0
    return 1
}

if [[ -z "$PERSISTENCE_PATH" ]]; then
    error "No EmComm-Tools persistence drive found (et-config folder). Please insert your USB drive."
fi

log "Found persistence at: ${PERSISTENCE_PATH}"

# ===========================================================================
# RESTORE FUNCTIONS
# ===========================================================================

restore_file() {
    local src="$1"
    local dest="$2"
    local name="$3"
    
    if [[ -f "$src" ]]; then
        mkdir -p "$(dirname "$dest")"
        if cp "$src" "$dest" 2>&1; then
            log "✓ Restored: $name"
            return 0
        else
            log "✗ Failed to restore: $name"
            return 1
        fi
    else
        log "⏭ Skip (not found on USB): $name"
    fi
    return 1
}

merge_user_json() {
    # Merge USB user.json with local, preserving sensitive fields like winlinkPasswd
    local src="$1"   # USB version
    local dest="$2"  # Local version
    
    log "Merging user.json..."
    
    if [[ ! -f "$src" ]]; then
        log "No USB user.json to merge"
        return 1
    fi
    
    mkdir -p "$(dirname "$dest")"
    
    # If local doesn't exist, just copy
    if [[ ! -f "$dest" ]]; then
        cp "$src" "$dest"
        log "✓ Restored: user.json (new)"
        return 0
    fi
    
    # Merge: USB values win, but preserve local winlinkPasswd if USB doesn't have it
    local local_passwd=$(jq -r '.winlinkPasswd // empty' "$dest" 2>/dev/null)
    local usb_passwd=$(jq -r '.winlinkPasswd // empty' "$src" 2>/dev/null)
    
    log "Local winlinkPasswd exists: $([[ -n "$local_passwd" ]] && echo yes || echo no)"
    log "USB winlinkPasswd exists: $([[ -n "$usb_passwd" ]] && echo yes || echo no)"
    
    # Start with USB version
    local merged=$(cat "$src")
    
    # If USB has no password but local does, preserve local password
    if [[ -z "$usb_passwd" && -n "$local_passwd" ]]; then
        merged=$(echo "$merged" | jq --arg pwd "$local_passwd" '. + {winlinkPasswd: $pwd}')
        log "  → Preserved local Winlink password"
    fi
    
    # Write merged result
    echo "$merged" | jq '.' > "$dest"
    log "✓ Restored: user.json (merged)"
    return 0
}

restore_dir() {
    local src="$1"
    local dest="$2"
    local name="$3"
    
    if [[ -d "$src" ]]; then
        mkdir -p "$dest"
        cp -r "$src"/* "$dest"/ 2>/dev/null || true
        log "✓ Restored: $name"
        return 0
    else
        log "⏭ Skip (not found on USB): $name"
    fi
    return 1
}

# ===========================================================================
# FIREFOX FUNCTIONS
# ===========================================================================

# Find the default Firefox profile directory
find_firefox_profile() {
    local firefox_dir="${HOME}/.mozilla/firefox"
    local profiles_ini="${firefox_dir}/profiles.ini"
    local profile_path=""
    
    if [[ ! -d "$firefox_dir" ]]; then
        return 1
    fi
    
    # Method 1: Check [Install*] section in profiles.ini (most reliable for Firefox ESR)
    if [[ -f "$profiles_ini" ]]; then
        local install_default
        install_default=$(grep -A2 '^\[Install' "$profiles_ini" 2>/dev/null | grep '^Default=' | head -1 | cut -d'=' -f2)
        if [[ -n "$install_default" && -d "${firefox_dir}/${install_default}" ]]; then
            profile_path="${firefox_dir}/${install_default}"
        fi
    fi
    
    # Method 2: Find profile with places.sqlite (actual user data)
    if [[ -z "$profile_path" || ! -f "${profile_path}/places.sqlite" ]]; then
        profile_path=$(find "$firefox_dir" -maxdepth 2 -name "places.sqlite" -type f 2>/dev/null | head -1 | xargs dirname 2>/dev/null)
    fi
    
    # Method 3: Try known profile patterns (prefer -esr for Debian)
    if [[ -z "$profile_path" || ! -d "$profile_path" ]]; then
        for pattern in "*.default-esr" "*.default-release" "*.default"; do
            profile_path=$(find "$firefox_dir" -maxdepth 1 -type d -name "$pattern" 2>/dev/null | head -1)
            [[ -d "$profile_path" ]] && break
        done
    fi
    
    if [[ -d "$profile_path" ]]; then
        echo "$profile_path"
        return 0
    fi
    
    return 1
}

# Check if Firefox is running
is_firefox_running() {
    pgrep -f "firefox-esr" > /dev/null 2>&1 || pgrep -f "firefox" > /dev/null 2>&1
}

restore_firefox_profile() {
    local src_dir="${PERSISTENCE_PATH}/configs/firefox"
    
    log "Firefox restore: starting..."
    
    # Check if we have Firefox backup data
    if [[ ! -d "$src_dir" ]] || [[ ! -f "${src_dir}/places.sqlite" ]]; then
        log "Firefox restore: No backup found"
        return 1
    fi
    
    log "Firefox restore: backup found at $src_dir"
    
    # Check if Firefox is running
    if is_firefox_running; then
        if is_live_boot; then
            # Live boot = fresh session, nothing to lose - kill Firefox and restore
            log "Firefox restore: Firefox running in live mode - killing it"
            pkill -f "firefox-esr" 2>/dev/null || pkill -f "firefox" 2>/dev/null || true
            sleep 2
        else
            # Installed system = user might have real data, don't risk it
            log "Firefox restore: Firefox running - skipping to prevent corruption"
            return 1
        fi
    fi
    
    # Find current Firefox profile
    local profile_dir
    profile_dir=$(find_firefox_profile)
    
    # If no profile exists, CREATE one for Firefox ESR
    if [[ -z "$profile_dir" || ! -d "$profile_dir" ]]; then
        log "Firefox restore: Creating new profile..."
        local firefox_dir="${HOME}/.mozilla/firefox"
        local profile_name
        
        # Generate random profile name like Firefox does
        profile_name="$(head /dev/urandom | tr -dc 'a-z0-9' | head -c 8).default-esr"
        profile_dir="${firefox_dir}/${profile_name}"
        
        # Create directory structure
        mkdir -p "$profile_dir"
        
        # Create profiles.ini
        cat > "${firefox_dir}/profiles.ini" << PROFILES_EOF
[Profile0]
Name=default-esr
IsRelative=1
Path=${profile_name}
Default=1

[General]
StartWithLastProfile=1
Version=2

[Install3B6073811A6ABF12]
Default=${profile_name}
Locked=1
PROFILES_EOF
        
        log "Firefox restore: Created profile: ${profile_name}"
    fi
    
    log "Firefox restore: Restoring to profile: $(basename "$profile_dir")"
    
    # Files to restore
    local files=(
        "places.sqlite"
        "places.sqlite-wal"
        "favicons.sqlite"
        "cookies.sqlite"
        "cookies.sqlite-wal"
        "logins.json"
        "key4.db"
        "cert9.db"
        "formhistory.sqlite"
        "permissions.sqlite"
        "prefs.js"
        "search.json.mozlz4"
        "handlers.json"
        "containers.json"
        "extension-settings.json"
        "extensions.json"
    )
    
    # Restore individual files
    for file in "${files[@]}"; do
        if [[ -f "${src_dir}/${file}" ]]; then
            cp "${src_dir}/${file}" "${profile_dir}/"
            log "Firefox restore: copied $file"
        fi
    done
    
    # Restore extensions directory
    if [[ -d "${src_dir}/extensions" ]]; then
        rm -rf "${profile_dir}/extensions" 2>/dev/null
        cp -r "${src_dir}/extensions" "${profile_dir}/"
        log "Firefox restore: copied extensions directory"
    fi
    
    # Restore storage (localStorage/IndexedDB)
    if [[ -d "${src_dir}/storage" ]]; then
        rm -rf "${profile_dir}/storage" 2>/dev/null
        cp -r "${src_dir}/storage" "${profile_dir}/"
        log "Firefox restore: copied storage directory"
    fi
    
    # Restore browser-extension-data
    if [[ -d "${src_dir}/browser-extension-data" ]]; then
        rm -rf "${profile_dir}/browser-extension-data" 2>/dev/null
        cp -r "${src_dir}/browser-extension-data" "${profile_dir}/"
        log "Firefox restore: copied browser-extension-data"
    fi
    
    log "✓ Restored: Firefox profile"
    return 0
}

# ===========================================================================
# THUNDERBIRD FUNCTIONS
# ===========================================================================

# Find the default Thunderbird profile directory
find_thunderbird_profile() {
    local thunderbird_dir="${HOME}/.thunderbird"
    local profiles_ini="${thunderbird_dir}/profiles.ini"
    local profile_path=""
    
    if [[ ! -d "$thunderbird_dir" ]]; then
        return 1
    fi
    
    # Method 1: Check [Install*] section in profiles.ini
    if [[ -f "$profiles_ini" ]]; then
        local install_default
        install_default=$(grep -A2 '^\[Install' "$profiles_ini" 2>/dev/null | grep '^Default=' | head -1 | cut -d'=' -f2)
        if [[ -n "$install_default" && -d "${thunderbird_dir}/${install_default}" ]]; then
            profile_path="${thunderbird_dir}/${install_default}"
        fi
    fi
    
    # Method 2: Find profile with prefs.js (actual user data)
    if [[ -z "$profile_path" || ! -f "${profile_path}/prefs.js" ]]; then
        profile_path=$(find "$thunderbird_dir" -maxdepth 2 -name "prefs.js" -type f 2>/dev/null | head -1 | xargs dirname 2>/dev/null)
    fi
    
    # Method 3: Try known profile patterns
    if [[ -z "$profile_path" || ! -d "$profile_path" ]]; then
        for pattern in "*.default-esr" "*.default-release" "*.default"; do
            profile_path=$(find "$thunderbird_dir" -maxdepth 1 -type d -name "$pattern" 2>/dev/null | head -1)
            [[ -d "$profile_path" ]] && break
        done
    fi
    
    if [[ -d "$profile_path" ]]; then
        echo "$profile_path"
        return 0
    fi
    
    return 1
}

# Check if Thunderbird is running
is_thunderbird_running() {
    pgrep -x "thunderbird" > /dev/null 2>&1
}

restore_thunderbird_profile() {
    local src_dir="${PERSISTENCE_PATH}/configs/thunderbird"
    local thunderbird_dir="${HOME}/.thunderbird"
    
    log "Thunderbird restore: starting..."
    
    # Check if Thunderbird is installed
    if ! command -v thunderbird &>/dev/null; then
        log "⏭ Thunderbird not installed - skipping restore"
        return 0
    fi
    
    # Check if we have Thunderbird backup data
    if [[ ! -d "$src_dir" ]] || [[ ! -f "${src_dir}/profile.tar.gz" ]]; then
        log "Thunderbird restore: No backup found"
        return 1
    fi
    
    log "Thunderbird restore: backup found at $src_dir"
    
    # Check if Thunderbird is running
    if is_thunderbird_running; then
        if is_live_boot; then
            # Live boot = fresh session, nothing to lose - kill Thunderbird and restore
            log "Thunderbird restore: Thunderbird running in live mode - killing it"
            pkill -x "thunderbird" 2>/dev/null || true
            sleep 2
        else
            # Installed system = user might have real data, don't risk it
            log "Thunderbird restore: Thunderbird running - skipping to prevent corruption"
            return 1
        fi
    fi
    
    # Remove existing .thunderbird if present (we're replacing it entirely)
    if [[ -d "$thunderbird_dir" ]]; then
        log "Thunderbird restore: Removing existing .thunderbird directory"
        rm -rf "$thunderbird_dir"
    fi
    
    # Extract entire .thunderbird directory (includes profiles.ini, installs.ini, and all profiles)
    log "Thunderbird restore: Extracting profile.tar.gz to ${HOME}..."
    
    if tar --no-same-owner -xzf "${src_dir}/profile.tar.gz" -C "${HOME}"; then
        local size_mb=$(du -sm "$thunderbird_dir" | cut -f1)
        log "✓ Restored: Thunderbird profile (${size_mb}MB)"
        return 0
    else
        log "✗ Failed to extract Thunderbird profile (tar error)"
        return 1
    fi
}

# ===========================================================================
# RESTORE ALL CONFIGS
# ===========================================================================

log "Starting config restores..."
RESTORED=0

# --- EmComm-Tools Core (MERGE to preserve winlinkPasswd) ---
if merge_user_json "${PERSISTENCE_PATH}/user.json" "${HOME}/.config/emcomm-tools/user.json"; then
    ((RESTORED++)) || true
fi

# --- Custom Radio Configs (BEFORE active radio so custom radios are available) ---
RADIOS_DIR="/opt/emcomm-tools/conf/radios.d"
USER_RADIOS="${HOME}/.config/emcomm-tools/radios.d"
RADIOS_USB="${PERSISTENCE_PATH}/configs/radios"
if [[ -d "$RADIOS_USB" ]] && [[ -n "$(ls -A "$RADIOS_USB" 2>/dev/null)" ]]; then
    mkdir -p "$USER_RADIOS"
    cp -f "$RADIOS_USB"/*.json "$USER_RADIOS/" 2>/dev/null || true
    # Create symlinks in system radios dir for each custom radio
    for f in "$USER_RADIOS"/*.json; do
        fname=$(basename "$f")
        rm -f "${RADIOS_DIR}/${fname}" 2>/dev/null || true
        ln -sf "$f" "${RADIOS_DIR}/${fname}" 2>/dev/null || true
    done
    RADIO_COUNT=$(ls -1 "$USER_RADIOS"/*.json 2>/dev/null | wc -l)
    log "✓ Restored: Custom radio configs ($RADIO_COUNT files)"
    ((RESTORED++)) || true
else
    log "⏭ Skip: Custom radio configs (none saved)"
fi

# --- Active Radio (restore symlink) ---
# Uses et-data group permissions (NO sudo needed - same as et-radio Flask app)
log "Restoring active radio..."
ACTIVE_RADIO_LINK="${RADIOS_DIR}/active-radio.json"
if [[ -f "${PERSISTENCE_PATH}/active-radio.txt" ]]; then
    RADIO_TARGET=$(cat "${PERSISTENCE_PATH}/active-radio.txt")
    log "Active radio target: $RADIO_TARGET"
    if [[ -f "${RADIOS_DIR}/${RADIO_TARGET}" ]]; then
        # Remove old symlink and create new one
        # NO sudo - user is in et-data group which has write permission on radios.d
        rm -f "$ACTIVE_RADIO_LINK" 2>/dev/null || true
        
        # Create relative symlink (same as et-radio.py does)
        cd "$RADIOS_DIR"
        ln -sf "$RADIO_TARGET" "active-radio.json"
        cd - > /dev/null
        
        # VERIFY the symlink was actually created
        if [[ -L "$ACTIVE_RADIO_LINK" ]]; then
            log "✓ Restored: Active radio ($RADIO_TARGET)"
            ((RESTORED++)) || true
        else
            log "✗ Failed: Active radio symlink not created (check et-data group membership)"
            log "  Run: groups | grep et-data"
            log "  If missing: sudo usermod -aG et-data \$USER && logout/login"
        fi
    else
        log "⚠ Radio config not found: $RADIO_TARGET"
    fi
else
    log "⏭ Skip: Active radio (no saved config)"
fi

# --- VarAC License (IMPORTANT!) ---
if restore_file "${PERSISTENCE_PATH}/varac/license.flag" "${HOME}/.config/emcomm-tools/varac/license.flag" "VarAC license"; then
