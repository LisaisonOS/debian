# --- Chattervox (config + keystore with signing keys) ---
CHATTERVOX_DIR="${HOME}/.chattervox"
if [[ -d "${PERSISTENCE_PATH}/configs/chattervox" ]]; then
    mkdir -p "$CHATTERVOX_DIR"
    if restore_file "${PERSISTENCE_PATH}/configs/chattervox/config.json" "${CHATTERVOX_DIR}/config.json" "Chattervox config"; then
