CALLSIGN="UNKNOWN"
if [[ -f "${HOME}/.config/emcomm-tools/user.json" ]]; then
    CALLSIGN=$(jq -r '.callsign // "UNKNOWN"' "${HOME}/.config/emcomm-tools/user.json")
fi

log ""
log "========================================"
log "RESTORE COMPLETE"
log "Callsign: ${CALLSIGN}"
log "Files restored: ${RESTORED}"
log "========================================"
