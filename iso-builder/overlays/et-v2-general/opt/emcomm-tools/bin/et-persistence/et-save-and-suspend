#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : February 2026
# Purpose : Save configs to USB then suspend - WITH VISUAL FEEDBACK
#

SCRIPT_DIR="/opt/emcomm-tools/bin/et-persistence"
DETECT_SCRIPT="${SCRIPT_DIR}/et-persistence-detect"

# Check if USB persistence exists
USB_PATH=$("$DETECT_SCRIPT" 2>/dev/null) || true

if [[ -z "$USB_PATH" ]]; then
    # No USB detected - offer Setup Wizard, proceed without saving, or cancel
    CHOICE=$(zenity --list --radiolist \
        --title="EmComm-Tools - Suspend" \
        --text="⚠ No USB drive detected.\n\nSaving is not available.\nYou can run the Setup Wizard to select a USB drive." \
        --column="Select" --column="Option" \
        TRUE "Run Setup Wizard" \
        FALSE "Suspend without saving" \
        --width=400 --height=250 2>/dev/null)

    case "$CHOICE" in
        "Run Setup Wizard")
            /opt/emcomm-tools/bin/et-flask-apps/et-firstboot/et-firstboot.py --force &
            ;;
        "Suspend without saving")
            systemctl suspend
            ;;
    esac
    exit 0
fi

# USB found - ask if user wants to save
CHOICE=$(zenity --list --radiolist \
    --title="EmComm-Tools - Suspend" \
    --text="USB backup drive detected.\n\nDo you want to save your configuration before suspend?" \
    --column="Select" --column="Option" \
    TRUE "Save & Suspend" \
    FALSE "Suspend without saving" \
    --width=400 --height=250 2>/dev/null)

case "$CHOICE" in
    "Save & Suspend")
        # Show progress window
        (
            echo "# Preparing backup..."
            echo "2"
            sleep 0.5

            echo "# Saving configuration..."
            echo "5"

            # Run save and capture output line by line
            "${SCRIPT_DIR}/et-persistence-save" 2>&1 | while IFS= read -r line; do
                # Extract meaningful status from output
                if [[ "$line" == *"✓ Saved:"* ]]; then
                    item=$(echo "$line" | sed 's/.*✓ Saved: //')
                    echo "# ✓ $item"
                elif [[ "$line" == *"Saving EmComm"* ]]; then
                    echo "# Saving configuration..."
                    echo "10"
                elif [[ "$line" == *"Firefox"* ]]; then
                    echo "# Saving Firefox (please wait)..."
                    echo "50"
                elif [[ "$line" == *"Thunderbird"* ]]; then
                    echo "# Saving Thunderbird..."
                    echo "70"
                elif [[ "$line" == *"Documents"* ]]; then
                    echo "# Saving Documents & Downloads..."
                    echo "78"
                elif [[ "$line" == *"WiFi"* ]]; then
                    echo "# Saving WiFi networks..."
                    echo "85"
                elif [[ "$line" == *"manifest"* ]]; then
                    echo "# Finalizing..."
                    echo "95"
                elif [[ "$line" == *"Save complete"* ]]; then
                    echo "# Save complete!"
                    echo "100"
                fi
            done

            sleep 1
        ) | zenity --progress \
            --title="EmComm-Tools - Saving..." \
            --text="Do NOT remove USB drive!" \
            --percentage=0 \
            --auto-close \
            --no-cancel \
            --width=400 \
            2>/dev/null

        # Show confirmation briefly
        zenity --info --title="EmComm-Tools" --text="✓ Configuration saved!\n\nSuspending now..." --timeout=2 2>/dev/null || true

        # Suspend
        systemctl suspend
        ;;

    "Suspend without saving")
        # Suspend directly
        systemctl suspend
        ;;

    *)
        # User cancelled (closed window)
        exit 0
        ;;
esac
