#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : January 2026
# Purpose : Prepare a PERSONALIZED EmComm-Tools Ready Kit for a specific operator
#
# Usage: et-prepare-personalized <mount-point> --call <CALLSIGN> --grid <GRID> [options]
#

set -e

VERSION="2.0.0"
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

# Default values
CALLSIGN=""
GRID=""
NAME=""
CLUB=""
LANGUAGE="fr"
WINLINK_PASS=""
VARA_LICENSE=""

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

error() {
    log "ERROR: $1"
    exit 1
}

show_usage() {
show_usage() {
    cat << 'EOF'
========================================================================
     EmComm-Tools PERSONALIZED Ready Kit Preparation
              "Cles en main" / "Turnkey Solution"
========================================================================

Usage: et-prepare-personalized <mount-point> --call <CALLSIGN> --grid <GRID> [options]

Required:
  <mount-point>         Path where USB is mounted
  --call <CALLSIGN>     Operator's callsign (e.g., VE2ABC)
  --grid <GRID>         Grid square (e.g., FN35fr)

Optional:
  --name <NAME>            Operator's name
  --club <CLUB>            Club callsign (e.g., VA2GCU)
  --lang <fr|en>           Language (default: fr)
  --winlink <PASSWORD>     Winlink password
  --vara-license <CODE>    VARA registration code (works for HF + FM)
  --help, -h               Show this help

Note: One VARA license works for BOTH VARA HF and VARA FM.
      Registration codes are from your VARA purchase (e.g., ppwhrposstfivysi).
      Leave empty for demo/free mode (speed limited).

Examples:
  # Basic personalization
  et-prepare-personalized /media/ventoy --call VE2ABC --grid FN35fr

  # Full personalization with VARA license
  et-prepare-personalized /media/ventoy \
      --call VE2ABC \
      --grid FN35fr \
      --name "Jean Tremblay" \
      --club VA2GCU \
      --lang fr \
      --vara-license "ppwhrposstfivysi"

Note: Run et-prepare-ready-kit FIRST to create the base structure and download maps!

EOF
}

# Create personalized user.json
create_user_config() {
    local base="$1"
    local persistence_dir="${base}/emcomm-data"
    
    log "Creating personalized user.json for ${CALLSIGN}..."
    
    cat > "${persistence_dir}/user.json" << EOF
{
  "callsign": "${CALLSIGN}",
  "grid": "${GRID}",
  "name": "${NAME}",
  "club": "${CLUB}",
  "language": "${LANGUAGE}",
  "winlinkPasswd": "${WINLINK_PASS}",
  "configured": true
}
EOF
    
    log "Created user.json"
}

# Update manifest with personalization info
update_manifest() {
    local base="$1"
    local persistence_dir="${base}/emcomm-data"
    
    cat > "${persistence_dir}/manifest.json" << EOF
{
  "version": "${VERSION}",
  "edition": "personalized",
  "callsign": "${CALLSIGN}",
  "prepared_for": "${NAME:-${CALLSIGN}}",
  "prepared_by": "VA2OPS",
  "prepared_date": "$(date -I)",
  "created": "$(date -Iseconds)",
  "last_save": "$(date -Iseconds)",
  "website": "https://emcomm-tools.ca"
}
EOF
    
    log "Updated manifest.json"
}

