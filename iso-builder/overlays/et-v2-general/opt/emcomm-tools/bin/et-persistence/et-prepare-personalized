# Main
main() {
    local mount_point=""
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                show_usage
                exit 0
                ;;
            --call)
                CALLSIGN=$(echo "$2" | tr '[:lower:]' '[:upper:]')
                shift 2
                ;;
            --grid)
                GRID="$2"
                shift 2
                ;;
            --name)
                NAME="$2"
                shift 2
                ;;
            --club)
                CLUB=$(echo "$2" | tr '[:lower:]' '[:upper:]')
                shift 2
                ;;
            --lang)
                LANGUAGE="$2"
                shift 2
                ;;
            --winlink)
                WINLINK_PASS="$2"
                shift 2
                ;;
            --vara-license)
                VARA_LICENSE="$2"
                shift 2
                ;;
            --varafm-license)
                # Accept for backwards compatibility, but use same license for both
                VARA_LICENSE="$2"
                shift 2
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                mount_point="$1"
                shift
                ;;
        esac
    done
    
    # Validate required arguments
    if [[ -z "$mount_point" ]]; then
        show_usage
        error "Mount point required"
    fi
    
    if [[ -z "$CALLSIGN" ]]; then
        error "Callsign required (--call)"
    fi
    
    if [[ -z "$GRID" ]]; then
        error "Grid square required (--grid)"
    fi
    
    if [[ ! -d "$mount_point" ]]; then
        error "Mount point does not exist: ${mount_point}"
    fi
    
    # Check if base structure exists
    if [[ ! -d "${mount_point}/emcomm-data" ]]; then
        error "emcomm-data not found. Run et-prepare-ready-kit first!"
    fi
    
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  EmComm-Tools PERSONALIZED Ready Kit"
    echo "═══════════════════════════════════════════════════════════════"
    echo "  Target:    ${mount_point}"
    echo "  Callsign:  ${CALLSIGN}"
    echo "  Grid:      ${GRID}"
    echo "  Name:      ${NAME:-N/A}"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    
    # Create all personalized configs
    create_user_config "$mount_point"
    update_manifest "$mount_point"
    create_pat_config "$mount_point"
    create_js8call_config "$mount_point"
    create_wsjtx_config "$mount_point"
    create_fldigi_config "$mount_point"
    create_direwolf_config "$mount_point"
    create_vara_hf_config "$mount_point"
    create_vara_fm_config "$mount_point"
    create_varac_config "$mount_point"
    create_welcome_file "$mount_point"
    
    # Show summary
    show_summary "$mount_point"
    
    echo ""
    echo "  ✅ Personalized Ready Kit complete for ${CALLSIGN}!"
    echo ""
    echo "  The operator will boot and see:"
    echo "    \"Bienvenue ${CALLSIGN}! 🎉\""
    echo ""
    echo "  All apps pre-configured - ZERO setup required!"
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    
    log "Personalization complete for ${CALLSIGN}!"
}

main "$@"
