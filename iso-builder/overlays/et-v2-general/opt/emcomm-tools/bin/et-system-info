# Author   : Gaston Gonzalez!/bin/bash
#
# Author   : Gaston Gonzalez
#
# Author   : Gaston Gonzalez Author   : William McKeehan
#
# Author   : Gaston Gonzalez Date     : 6 October 2024
#
# Author   : Gaston Gonzalez Updated  : 26 February 2026 - Sylvain Deguire (VA2OPS)
#
# Author   : Gaston Gonzalez             Added audio-only radio detection (DigiRig Lite) in et-cat check
#
# Author   : Gaston Gonzalez Purpose  : Utility script for dumping system information

function usage() {
  echo "Usage: $(basename $0) <command>"
  echo "  active-radio  - Display model of active radio" 
  echo "  callsign      - Current callsign"
  echo "  et-audio      - Show state of audio interface"
  echo "  et-audio-card - Display audio card and device: <card>,<device>"
  echo "  et-cat        - Show state of CAT control interface"
  echo "  et-gps        - Show state of GPS interface"
  echo "  et-time       - Show if time is synched via GPS"
  echo "  et-mode       - Show current mode (via supervisor)"
  echo "  et-bluetooth  - Show state of Bluetooth TNC interface"
  echo "  et-sdr        - Show state of SDR interface"
  echo "  grid          - Current grid square defined by user"
  echo "  ip            - System IP address"
  echo "  release       - LiaisonOS release"
}

if [ $#
# Author   : Gaston Gonzalez -ne 1 ]; then
  usage
  exit 1
fi

[ -z "$ET_USER_CONFIG" ] && ET_USER_CONFIG="${HOME}/.config/emcomm-tools/user.json"

case $1 in
  active-radio)
    if [ -L  "${ET_HOME}/conf/radios.d/active-radio.json" ]; then
      cat "${ET_HOME}/conf/radios.d/active-radio.json" | jq -r .model
    else
      echo "No radio selected"
    fi 
    ;;
  callsign)
    cat ${ET_USER_CONFIG} | jq -r .callsign
    ;;
  grid)
    FALLBACK_GRID=$(jq -r -e '.grid' ${ET_USER_CONFIG})
    GEO_CONF=/tmp/geo.tmp

    curl -f -s "http://localhost:1981/api/geo/position" > ${GEO_CONF}
    if [[ $? -eq 0 ]]; then
      API_GRID=$(jq -r -e '.position.gridSquare' ${GEO_CONF})
      [[ -e ${GEO_CONF} ]] && rm ${GEO_CONF}
      if [[ $? -eq 0 ]]; then
        echo ${API_GRID}
        exit
      fi
    fi

    echo ${FALLBACK_GRID}

    ;;
  et-audio)

    #
# Author   : Gaston Gonzalez 1. Check if the symlink was created by the udev rules
    if [ -e /dev/et-audio ]; then 

      UDEV_OUT=$(udevadm info /dev/et-audio | grep ET_DEVICE)
      if [ $? -eq 0 ]; then

        #
# Author   : Gaston Gonzalez Display friendly audio device name
        ET_DEVICE=$(udevadm info /dev/et-audio | grep ET_DEVICE | cut -d"=" -f2)
        case $ET_DEVICE in
          "DIGIRIG_LITE")
            echo "DigiRig Lite"
          ;;
          "DIGIRIG_MOBILE")
            echo "DigiRig Mobile"
          ;;
          *)
            echo $ET_DEVICE
          ;;
        esac

      else
        echo "Connected" 
      fi

    else
      echo "Not connected" 
    fi

    ;;
  et-audio-card)

    #
# Author   : Gaston Gonzalez 1. Check if the symlink was created by the udev rules
    if [ -e /dev/et-audio ]; then 

       #
# Author   : Gaston Gonzalez 2. Check that this device was properly tagged with the ET_AUDIO env variable with a udev rule
       APLAY_OUT=$(arecord -l | grep ET_AUDIO)
       if [ $? -eq 0 ]; then
         AUDIO_CARD=$(echo $APLAY_OUT | cut -d":" -f1 | awk '{print $2}')
         AUDIO_DEVICE=$(echo $APLAY_OUT | cut -d"," -f2 | cut -d":" -f1 | awk '{print $2}')
         echo $AUDIO_CARD,$AUDIO_DEVICE
       else
         exit 1
       fi
    else
      exit 1
    fi

    ;;
  et-cat)

    if [ ! -L "${ET_HOME}/conf/radios.d/active-radio.json" ]; then
      echo "N/A"
      exit 0
    fi

    #
# Author   : Gaston Gonzalez Audio-only radios (e.g. DigiRig Lite) have no /dev/et-cat but run rigctld
    #
# Author   : Gaston Gonzalez in dummy mode. Detect via rigctrl.id in the active radio config.
    RIG_ID=$(jq -r '.rigctrl.id // empty' "${ET_HOME}/conf/radios.d/active-radio.json" 2>/dev/null)
    if [ "$RIG_ID" = "1" ]; then
      #
# Author   : Gaston Gonzalez Dummy rig (audio-only, no CAT hardware)
      systemctl status rigctld --no-pager > /dev/null 2>&1
      if [ $? -eq 0 ]; then
        echo "Audio only"
      else
        echo "Not connected"
      fi
      exit 0
    fi

    #
# Author   : Gaston Gonzalez 1. Check if the symlink was created by the udev rules
    if [ -e /dev/et-cat ]; then

      #
# Author   : Gaston Gonzalez 2. Check if the rigctl systemd unit is running properly
      systemctl status rigctld --no-pager > /dev/null
      if [ $? -eq 0 ]; then

        #
# Author   : Gaston Gonzalez Note: I am disabling the VFO read as it causes issues with serval Icom
        #
# Author   : Gaston Gonzalez radios and results in the VFO changing momentarily during this client
        #
# Author   : Gaston Gonzalez request. It causes issues during TX and RX. If it is not bulletproof,
        #
# Author   : Gaston Gonzalez features like this will be turned off. This is a problem given that
        #
# Author   : Gaston Gonzalez Conky calls this method every 10 seconds.
        #
# Author   : Gaston Gonzalez
        #
# Author   : Gaston Gonzalez 3. Grab and format frequency
        #
# Author   : Gaston GonzalezFREQ=$(timeout 1 rigctl -m 2 f)
        #
# Author   : Gaston Gonzalezif [ $? -eq 0 ]; then
        #
# Author   : Gaston Gonzalez  printf "%'d MHz\n" "$FREQ" | sed 's|,|.|g'
        #
# Author   : Gaston Gonzalezelse
        #
# Author   : Gaston Gonzalez  echo "Connected. Can't access VFO";
        #
# Author   : Gaston Gonzalezfi
        echo "Connected";
      else
        echo "Connected. No rig control"
      fi
    else
      echo "Not connected";
    fi

    ;; 
  et-sdr)
    #
# Author   : Gaston Gonzalez 1. Check if the symlink was created by the udev rules
    if [ -e /dev/et-sdr ]; then
        echo "Connected";
    else
      echo "Not connected";
    fi

    ;;
  et-bluetooth)
    #
# Author   : Gaston Gonzalez Check if Bluetooth TNC serial port exists (bound via rfcomm)
    if [ -e /dev/rfcomm0 ]; then
        echo "Connected";
    else
      echo "Not connected";
    fi

    ;;
  et-gps)

    #
# Author   : Gaston Gonzalez 1. Check if the symlink was created by the udev rules
    if [ -e /dev/et-gps ]; then 

      #
# Author   : Gaston Gonzalez 2. Check if the gpsd systemd unit is running properly
      systemctl status gpsd --no-pager > /dev/null 
      if [ $? -eq 0 ]; then

        #
# Author   : Gaston Gonzalez 3. Obtain the current GPS mode
        GPS_JSON=$(gpspipe -w -n 10 | grep -m 1 TPV)
        if [ $? -eq 0 ]; then
          GPS_MODE=$(echo $GPS_JSON | jq --exit-status -r .mode)

          case $GPS_MODE in
            1)
              echo "No fix"
            ;;
            2)
              echo "2D fix"
            ;;
            3)
              LAT=$(echo $GPS_JSON | jq -r .lat)
              LON=$(echo $GPS_JSON | jq -r .lon)
              printf "%.5f,%.5f\n" $LAT $LON
            ;;
            *)
              echo "Unknown mode"
            ;;
          esac 

        else
          echo "Connected. Can't decode"
        fi

      else
        echo "Connected. gpsd not running"
      fi
    else 
      echo "Not connected" 
    fi

    ;; 
  et-mode)
    #
# Author   : Gaston Gonzalez Query supervisor for current mode
    SUPERVISOR_SOCK="/run/user/$(id -u)/et-supervisor.sock"
    if [ -S "$SUPERVISOR_SOCK" ]; then
      MODE=$(et-supervisor-ctl status 2>/dev/null | head -1 | sed 's/^Mode: //')
      if [ -n "$MODE" ]; then
        echo "$MODE"
      else
        echo "No mode running"
      fi
    else
      echo "Supervisor not running"
    fi

    ;;
  et-time)
    ET_OUT=$(${ET_HOME}/bin/et-time)
    if [ $? -eq 0 ]; then
      echo "Yes"
    else
      echo "No"
    fi

    ;;
  ip)
    hostname -I | awk '{print $1}'
    ;;
  release)
    grep DISTRIB_DESCRIPTION /etc/lsb-release | sed 's|"||g' | awk '{print $1}' | cut -d"=" -f2
    ;;  
  *)
    echo "Command not supported."
    usage
    exit 1
    ;;
esac
