#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : January 2026
# Purpose : Wrapper script for Navit with EmComm-Tools integration
#
# Features:
# - Sets home position from grid square in user.json
# - Configures reasonable zoom level
# - Launches Navit
#

NAVIT_CONF_DIR="${HOME}/.navit"
NAVIT_CONF_FILE="${NAVIT_CONF_DIR}/navit.xml"
NAVIT_CONF_TEMPLATE="/etc/navit/navit.xml"
NAVIT_CENTER_FILE="${NAVIT_CONF_DIR}/center.txt"
NAVIT_MAPS_DIR="${HOME}/.navit/maps"

# Default zoom level - good for seeing local streets
DEFAULT_ZOOM=256

# Update navit.xml mapset to include all .bin files found
update_mapset() {
    local maps_dir="$NAVIT_MAPS_DIR"
    
    echo "Checking maps directory: $maps_dir"
    
    if [[ ! -d "$maps_dir" ]]; then
        echo "WARNING: Maps directory not found: $maps_dir"
        return 1
    fi
    
    # List what's actually in the directory
    echo "Contents of $maps_dir:"
    ls -la "$maps_dir"/ 2>/dev/null || echo "  (empty or error)"
    echo ""
    
    # Find all .bin files (follow symlinks with -L)
    local bin_files=()
    
    # Try ls first (handles symlinks better)
    if ls "$maps_dir"/*.bin &>/dev/null; then
        for f in "$maps_dir"/*.bin; do
            [[ -e "$f" || -L "$f" ]] && bin_files+=("$f")
        done
    fi
    
    # Fallback to find if ls didn't work
    if [[ ${#bin_files[@]} -eq 0 ]]; then
        while IFS= read -r -d '' file; do
            bin_files+=("$file")
        done < <(find -L "$maps_dir" -maxdepth 1 -name "*.bin" -print0 2>/dev/null | sort -z)
    fi
    
    if [[ ${#bin_files[@]} -eq 0 ]]; then
        echo "WARNING: No .bin map files found in $maps_dir"
        return 1
    fi
    
    echo "Found ${#bin_files[@]} map(s):"
    for f in "${bin_files[@]}"; do
        echo "  - $(basename "$f")"
    done
    
    # Build new mapset XML block
    local mapset_content="<mapset enabled=\"yes\">\n"
    for bin_file in "${bin_files[@]}"; do
        mapset_content+="        <map type=\"binfile\" enabled=\"yes\" data=\"${bin_file}\"/>\n"
    done
    mapset_content+="    </mapset>"
    
    # Backup original
    if [[ ! -f "${NAVIT_CONF_FILE}.orig" ]]; then
        cp "$NAVIT_CONF_FILE" "${NAVIT_CONF_FILE}.orig"
    fi
    
    # Replace the OSM mapset section
    # We need to find the mapset that contains binfile and replace it
    # Using awk for multi-line replacement
    awk -v new_mapset="$mapset_content" '
    /<mapset enabled="yes">/ {
        in_mapset=1
        # Check if this is the binfile mapset by peeking ahead
        getline nextline
        if (nextline ~ /binfile/) {
            # This is our target mapset - print new one instead
            printf "%s\n", new_mapset
            # Skip until </mapset>
            while (getline && !/<\/mapset>/) {}
            next
        } else {
            # Not our mapset, print both lines
            print $0
            print nextline
            next
        }
    }
    { print }
    ' "$NAVIT_CONF_FILE" > "${NAVIT_CONF_FILE}.tmp"
    
    mv "${NAVIT_CONF_FILE}.tmp" "$NAVIT_CONF_FILE"
    
    echo "Updated mapset in navit.xml"
    return 0
}

usage() {
    echo "usage: $(basename $0) <command>"
    echo "  <command>"
    echo "    start           - Start Navit (updates config first)"
    echo "    update-config   - Update home position from grid square"
    echo "    update-maps     - Update mapset with all .bin files found"
    echo "    set-home        - Set home position interactively"
    echo "    grid-to-lonlat  - Convert grid square to lon/lat (test)"
}

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

# Convert Maidenhead grid square to longitude/latitude
# Usage: grid_to_lonlat "FN35fl"
# Returns: "lon lat" (Navit format - longitude first!)
grid_to_lonlat() {
    local grid="$1"
    
    # Validate grid format (4 or 6 characters)
    if [[ ! "$grid" =~ ^[A-Ra-r]{2}[0-9]{2}([A-Xa-x]{2})?$ ]]; then
        echo "ERROR: Invalid grid square format: $grid" >&2
        return 1
    fi
    
    # Convert to uppercase for field
    local field1=$(echo "${grid:0:1}" | tr 'a-r' 'A-R')
    local field2=$(echo "${grid:1:1}" | tr 'a-r' 'A-R')
    local square1="${grid:2:1}"
    local square2="${grid:3:1}"
    
    # Field: A=0 to R=17
    local lon_field=$(( $(printf '%d' "'$field1") - 65 ))
    local lat_field=$(( $(printf '%d' "'$field2") - 65 ))
    
    # Base longitude: field * 20 - 180
    # Base latitude: field * 10 - 90
    local lon=$(echo "scale=6; $lon_field * 20 - 180 + $square1 * 2" | bc)
    local lat=$(echo "scale=6; $lat_field * 10 - 90 + $square2 * 1" | bc)
    
    # If 6-character grid, add subsquare precision
    if [[ ${#grid} -ge 6 ]]; then
        local sub1=$(echo "${grid:4:1}" | tr 'A-X' 'a-x')
        local sub2=$(echo "${grid:5:1}" | tr 'A-X' 'a-x')
        
        # Subsquare: a=0 to x=23
        local lon_sub=$(( $(printf '%d' "'$sub1") - 97 ))
        local lat_sub=$(( $(printf '%d' "'$sub2") - 97 ))
        
        # Add subsquare offset + center offset
        lon=$(echo "scale=6; $lon + $lon_sub * (2.0/24.0) + (1.0/24.0)" | bc)
        lat=$(echo "scale=6; $lat + $lat_sub * (1.0/24.0) + (1.0/48.0)" | bc)
    else
        # 4-character grid - use center of square
        lon=$(echo "scale=6; $lon + 1" | bc)
        lat=$(echo "scale=6; $lat + 0.5" | bc)
    fi
    
    # Return in Navit format: longitude latitude
    echo "$lon $lat"
}

# Update navit.xml with home position from grid
update_navit_config() {
    local lon="$1"
    local lat="$2"
    local zoom="${3:-$DEFAULT_ZOOM}"
    
    # Ensure config directory exists
    mkdir -p "$NAVIT_CONF_DIR"
    
    # Copy template if no config exists
    if [[ ! -f "$NAVIT_CONF_FILE" ]]; then
        if [[ -f "$NAVIT_CONF_TEMPLATE" ]]; then
            cp "$NAVIT_CONF_TEMPLATE" "$NAVIT_CONF_FILE"
            echo "Created navit.xml from template"
        else
            echo "ERROR: No navit.xml template found at $NAVIT_CONF_TEMPLATE"
            return 1
        fi
    fi
    
    # Update center position in navit.xml
    # Match: center="anything" and replace with new coordinates
    if grep -q 'center="' "$NAVIT_CONF_FILE"; then
        sed -i "s|center=\"[^\"]*\"|center=\"$lon $lat\"|" "$NAVIT_CONF_FILE"
        echo "Updated center to: $lon $lat"
    fi
    
    # Update zoom level
    if grep -q 'zoom="' "$NAVIT_CONF_FILE"; then
        sed -i "s|zoom=\"[^\"]*\"|zoom=\"$zoom\"|" "$NAVIT_CONF_FILE"
        echo "Updated zoom to: $zoom"
    fi
    
    # Also update center.txt if it exists (Navit remembers last position here)
    # Format in center.txt is: 0xLON 0xLAT (mercator projection hex values)
    # We'll delete it to force Navit to use navit.xml center on next start
    if [[ -f "$NAVIT_CENTER_FILE" ]]; then
        rm -f "$NAVIT_CENTER_FILE"
        echo "Removed center.txt (will use navit.xml position)"
    fi
    
    return 0
}

# Read grid from user config and update Navit
update_from_user_config() {
    local user_config="${ET_USER_CONFIG:-${HOME}/.config/emcomm-tools/user.json}"
    
    if [[ ! -f "$user_config" ]]; then
        echo "WARNING: User config not found: $user_config"
        echo "Run et-firstboot or et-user to configure."
        return 1
    fi
    
    local grid=$(jq -r '.grid // empty' "$user_config")
    
    if [[ -z "$grid" || "$grid" == "null" ]]; then
        echo "WARNING: No grid square set in user config"
        echo "Navit will use default position"
        return 1
    fi
    
    echo "Grid square from config: $grid"
    
    # Convert grid to lon/lat
    local coords=$(grid_to_lonlat "$grid")
    if [[ $? -ne 0 ]]; then
        echo "ERROR: Failed to convert grid square"
        return 1
    fi
    
    local lon=$(echo "$coords" | cut -d' ' -f1)
    local lat=$(echo "$coords" | cut -d' ' -f2)
    
    echo "Coordinates: Lon=$lon, Lat=$lat"
    
    # Update navit config
    update_navit_config "$lon" "$lat" "$DEFAULT_ZOOM"
    
    return 0
}

# Interactive home position setting
set_home_interactive() {
    echo ""
    echo "Set Navit Home Position"
    echo "======================="
    echo ""
    echo "Enter coordinates in one of these formats:"
    echo "  1) Grid square (e.g., FN35fl)"
    echo "  2) Decimal degrees: lon,lat (e.g., -73.5,45.5)"
    echo ""
    read -p "Enter position: " input
    
    local lon lat
    
    # Check if it looks like a grid square
    if [[ "$input" =~ ^[A-Ra-r]{2}[0-9]{2}([A-Xa-x]{2})?$ ]]; then
        local coords=$(grid_to_lonlat "$input")
        lon=$(echo "$coords" | cut -d' ' -f1)
        lat=$(echo "$coords" | cut -d' ' -f2)
        echo "Grid $input -> Lon=$lon, Lat=$lat"
    # Check if it looks like lon,lat
    elif [[ "$input" =~ ^-?[0-9]+\.?[0-9]*,-?[0-9]+\.?[0-9]*$ ]]; then
        lon=$(echo "$input" | cut -d',' -f1)
        lat=$(echo "$input" | cut -d',' -f2)
    else
        echo "ERROR: Invalid format"
        return 1
    fi
    
    read -p "Zoom level [$DEFAULT_ZOOM]: " zoom
    zoom="${zoom:-$DEFAULT_ZOOM}"
    
    update_navit_config "$lon" "$lat" "$zoom"
    echo ""
    echo "Home position updated!"
}

start_navit() {
    # Update config from user settings (position)
    update_from_user_config
    
    # Update mapset with all available maps
    update_mapset
    
    echo ""
    echo "Starting Navit..."
    navit
}

# Main command handler
case "$1" in
    start)
        start_navit
        ;;
    update-config)
        update_from_user_config
        ;;
    update-maps)
        update_mapset
        ;;
    set-home)
        set_home_interactive
        ;;
    grid-to-lonlat)
        if [[ -z "$2" ]]; then
            echo "Usage: $0 grid-to-lonlat <grid>"
            echo "Example: $0 grid-to-lonlat FN35fl"
            exit 1
        fi
        grid_to_lonlat "$2"
        ;;
    *)
        echo "Invalid command: $1"
        usage
        exit 1
        ;;
esac
