#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : 16 January 2026
# Updated : 25 January 2026 - Added persistence drive support
# Purpose : Convert OSM .pbf maps to Navit .bin format
#
# Usage: et-navit-maps
#

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Swap file tracking
SWAP_FILE=""
SWAP_CREATED=false

# Detect LiaisonOS persistence USB drive
# Returns the USB path if found, empty otherwise
detect_emcomm_usb() {
    local search_paths=()
    
    # Check /media/$USER paths
    if [[ -d "/media/$USER" ]]; then
        for drive in /media/$USER/*; do
            [[ -d "$drive" ]] && search_paths+=("$drive")
        done
    fi
    
    # Check /run/media/$USER paths
    if [[ -d "/run/media/$USER" ]]; then
        for drive in /run/media/$USER/*; do
            [[ -d "$drive" ]] && search_paths+=("$drive")
        done
    fi
    
    # Look for et-config folder (persistence marker)
    for usb_path in "${search_paths[@]}"; do
        if [[ -d "$usb_path/et-config" ]]; then
            echo "$usb_path"
            return 0
        fi
    done
    
    # Fallback: look for my-maps folder (firstboot created)
    for usb_path in "${search_paths[@]}"; do
        if [[ -d "$usb_path/my-maps" ]]; then
            echo "$usb_path"
            return 0
        fi
    done
    
    return 1
}

# Cleanup function
cleanup_swap() {
    if [[ "$SWAP_CREATED" == true && -n "$SWAP_FILE" ]]; then
        echo ""
        echo -e "${CYAN}Cleaning up temporary swap...${NC}"
        sudo swapoff "$SWAP_FILE" 2>/dev/null
        rm -f "$SWAP_FILE"
        echo -e "${GREEN}✓ Swap removed${NC}"
    fi
}

# Set trap to cleanup on exit
trap cleanup_swap EXIT

# Check if running in live mode (no swap, low memory)
check_live_mode() {
    local swap_total=$(free -b | awk '/Swap:/ {print $2}')
    local mem_available=$(free -b | awk '/Mem:/ {print $7}')
    local mem_available_mb=$((mem_available / 1024 / 1024))
    
    # If no swap and less than 2GB available = live mode
    if [[ $swap_total -eq 0 && $mem_available_mb -lt 2048 ]]; then
        return 0  # true - live mode
    fi
    return 1  # false - installed mode
}

# Create temporary swap on USB
create_temp_swap() {
    local usb_path="$1"
    local swap_size_mb="${2:-2048}"  # Default 2GB
    
    SWAP_FILE="$usb_path/.et-temp-swap"
    
    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}  Live Mode Detected - Limited RAM Available${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "  Map conversion requires significant memory."
    echo -e "  Creating temporary swap file on USB drive (${swap_size_mb}MB)..."
    echo -e "  ${CYAN}This will be slower but will work!${NC}"
    echo ""
    
    # Check available space on USB
    local usb_free_mb=$(df -BM "$usb_path" | awk 'NR==2 {gsub(/M/,"",$4); print $4}')
    if [[ $usb_free_mb -lt $((swap_size_mb + 500)) ]]; then
        echo -e "${RED}Error: Not enough space on USB for swap file${NC}"
        echo -e "       Need ${swap_size_mb}MB, only ${usb_free_mb}MB available"
        return 1
    fi
    
    # Create swap file
    echo -e "  Creating swap file..."
    if ! sudo dd if=/dev/zero of="$SWAP_FILE" bs=1M count=$swap_size_mb status=progress 2>/dev/null; then
        echo -e "${RED}Error: Failed to create swap file${NC}"
        return 1
    fi
    
    sudo chmod 600 "$SWAP_FILE"
    
    echo -e "  Initializing swap..."
    if ! sudo mkswap "$SWAP_FILE" >/dev/null 2>&1; then
        echo -e "${RED}Error: Failed to initialize swap${NC}"
        rm -f "$SWAP_FILE"
        return 1
    fi
    
    echo -e "  Enabling swap..."
    if ! sudo swapon "$SWAP_FILE" 2>/dev/null; then
        echo -e "${RED}Error: Failed to enable swap${NC}"
        rm -f "$SWAP_FILE"
        return 1
    fi
    
    SWAP_CREATED=true
    echo ""
    echo -e "${GREEN}✓ Temporary swap created successfully${NC}"
    echo ""
    
    return 0
}

echo ""
echo -e "${CYAN}========================================"
echo " LiaisonOS - Navit Map Conversion"
echo "========================================${NC}"
echo ""
echo -e "${YELLOW}⚠️  Recommended: External SSD or USB drive 32GB+${NC}"
echo -e "   Map conversion is memory and storage intensive."
echo -e "   A basic USB stick may be very slow or fail."
echo ""

# Step 1: Check for LiaisonOS persistence drive
EMCOMM_USB=$(detect_emcomm_usb)

if [[ -n "$EMCOMM_USB" ]]; then
    echo -e "${GREEN}✓ Found LiaisonOS USB: ${CYAN}$EMCOMM_USB${NC}"
    echo ""
    echo -e "${YELLOW}Where do you want to save Navit maps?${NC}"
    echo ""
    echo "  1) LiaisonOS USB drive (recommended)"
    echo "  2) Local drive (~/.navit/maps)"
    echo "  3) Other USB/External drive"
    echo ""
    read -p "Select [1-3]: " DEST_CHOICE
    
    case $DEST_CHOICE in
        1)
            USB_PATH="$EMCOMM_USB"
            PBF_DIR="$USB_PATH/my-maps"
            NAVIT_DIR="$USB_PATH/navit-maps"
            CREATE_SYMLINKS=true
            ;;
        2)
            PBF_DIR="$HOME/my-maps"
            NAVIT_DIR="$HOME/.navit/maps"
            CREATE_SYMLINKS=false
            ;;
        3)
            DEST_CHOICE="manual"
            ;;
        *)
            echo -e "${RED}Invalid selection${NC}"
            exit 1
            ;;
    esac
else
    echo -e "${YELLOW}Where do you want to save Navit maps?${NC}"
    echo ""
    echo "  1) Local drive (~/.navit/maps)"
    echo "  2) USB/External drive"
    echo ""
    read -p "Select [1-2]: " DEST_CHOICE
    
    case $DEST_CHOICE in
        1)
            PBF_DIR="$HOME/my-maps"
            NAVIT_DIR="$HOME/.navit/maps"
            CREATE_SYMLINKS=false
            ;;
        2)
            DEST_CHOICE="manual"
            ;;
        *)
            echo -e "${RED}Invalid selection${NC}"
            exit 1
            ;;
    esac
fi

# Handle manual USB selection
if [[ "$DEST_CHOICE" == "manual" ]]; then
    # Find mounted USB drives
    echo ""
    echo -e "${YELLOW}Available USB/External drives:${NC}"
    echo ""
    
    # List drives in /media/$USER
    DRIVES=()
    i=1
    for drive in /media/$USER/*; do
        if [[ -d "$drive" ]]; then
            echo "  $i) $drive"
            DRIVES+=("$drive")
            ((i++))
        fi
    done
    
    if [[ ${#DRIVES[@]} -eq 0 ]]; then
        echo -e "${RED}No USB drives found in /media/$USER/${NC}"
        echo "Please mount your USB drive and try again."
        exit 1
    fi
    
    echo ""
    read -p "Select drive [1-${#DRIVES[@]}]: " DRIVE_CHOICE
    
    if [[ $DRIVE_CHOICE -lt 1 || $DRIVE_CHOICE -gt ${#DRIVES[@]} ]]; then
        echo -e "${RED}Invalid selection${NC}"
        exit 1
    fi
    
    USB_PATH="${DRIVES[$((DRIVE_CHOICE-1))]}"
    PBF_DIR="$USB_PATH/my-maps"
    NAVIT_DIR="$USB_PATH/navit-maps"
    CREATE_SYMLINKS=true
fi

echo ""
echo -e "Source:      ${CYAN}$PBF_DIR${NC}"
echo -e "Destination: ${CYAN}$NAVIT_DIR${NC}"
echo ""

# Check source exists
if [[ ! -d "$PBF_DIR" ]]; then
    echo -e "${RED}Error: Source directory not found: $PBF_DIR${NC}"
    echo "Download OSM maps first using et-firstboot or manually."
    exit 1
fi

# Create destination
mkdir -p "$NAVIT_DIR"

# Build list of available .pbf files
PBF_FILES=()
while IFS= read -r -d '' file; do
    PBF_FILES+=("$file")
done < <(find "$PBF_DIR" -maxdepth 1 -name "*.osm.pbf" -print0 2>/dev/null | sort -z)

PBF_COUNT=${#PBF_FILES[@]}

if [[ $PBF_COUNT -eq 0 ]]; then
    echo -e "${YELLOW}No .osm.pbf files found in $PBF_DIR${NC}"
    exit 0
fi

echo -e "Found ${GREEN}$PBF_COUNT${NC} map(s) available:"
echo ""

# Display list with status
i=1
for pbf_file in "${PBF_FILES[@]}"; do
    filename=$(basename "$pbf_file")
    base_name="${filename%-latest.osm.pbf}"
    bin_file="$NAVIT_DIR/${base_name}.bin"
    
    if [[ -f "$bin_file" ]]; then
        echo -e "  $i) ${GREEN}[converted]${NC} $filename"
    else
        echo -e "  $i) $filename"
    fi
    ((i++))
done

echo ""
echo -e "  ${CYAN}a) Convert ALL maps${NC}"
echo -e "  ${CYAN}q) Quit${NC}"
echo ""
echo -e "${YELLOW}Enter map numbers to convert (space-separated), 'a' for all, or 'q' to quit:${NC}"
read -p "> " SELECTION

if [[ "$SELECTION" == "q" || "$SELECTION" == "Q" ]]; then
    echo "Exiting."
    exit 0
fi

# Build list of selected files
SELECTED_FILES=()

if [[ "$SELECTION" == "a" || "$SELECTION" == "A" ]]; then
    # Select all
    SELECTED_FILES=("${PBF_FILES[@]}")
else
    # Parse space-separated numbers
    for num in $SELECTION; do
        if [[ "$num" =~ ^[0-9]+$ && $num -ge 1 && $num -le $PBF_COUNT ]]; then
            SELECTED_FILES+=("${PBF_FILES[$((num-1))]}")
        else
            echo -e "${YELLOW}Warning: Invalid selection '$num' ignored${NC}"
        fi
    done
fi

if [[ ${#SELECTED_FILES[@]} -eq 0 ]]; then
    echo -e "${RED}No valid maps selected.${NC}"
    exit 1
fi

echo ""
echo -e "Selected ${GREEN}${#SELECTED_FILES[@]}${NC} map(s) to process"
echo ""

# Check if we're in live mode and need swap (USB only)
if [[ "$CREATE_SYMLINKS" == true && -n "$USB_PATH" ]]; then
    if check_live_mode; then
        if ! create_temp_swap "$USB_PATH" 2048; then
            echo ""
            echo -e "${RED}Cannot proceed without enough memory.${NC}"
            echo -e "Try closing other applications or run on an installed system."
            exit 1
        fi
    fi
    
    # CRITICAL: Set TMPDIR to USB to avoid filling RAM with temp files
    export TMPDIR="$USB_PATH/tmp"
    mkdir -p "$TMPDIR"
    echo -e "${CYAN}Temp directory: $TMPDIR${NC}"
    echo ""
    
    # Change to USB directory for maptool working files
    cd "$USB_PATH"
fi

# Convert selected files
CONVERTED=0
SKIPPED=0
FAILED=0

for pbf_file in "${SELECTED_FILES[@]}"; do
    [[ ! -f "$pbf_file" ]] && continue
    
    filename=$(basename "$pbf_file")
    # Remove -latest.osm.pbf to get base name, then add .bin
    base_name="${filename%-latest.osm.pbf}"
    bin_file="$NAVIT_DIR/${base_name}.bin"
    
    # Skip if already converted
    if [[ -f "$bin_file" ]]; then
        echo -e "${GREEN}✓${NC} $filename (already converted)"
        ((SKIPPED++))
        continue
    fi
    
    echo -e "${YELLOW}Converting:${NC} $filename"
    echo "  This may take several minutes..."
    
    if maptool --protobuf -i "$pbf_file" "$bin_file" 2>&1 | tail -5; then
        if [[ -f "$bin_file" ]]; then
            echo -e "${GREEN}✓ Done${NC}"
            ((CONVERTED++))
        else
            echo -e "${RED}✗ Failed - output file not created${NC}"
            ((FAILED++))
        fi
    else
        echo -e "${RED}✗ Failed${NC}"
        ((FAILED++))
        # Clean up partial file
        [[ -f "$bin_file" ]] && rm "$bin_file"
    fi
    echo ""
done

# Create symlinks if USB was selected
if [[ "$CREATE_SYMLINKS" == true ]]; then
    echo -e "${CYAN}Creating symlinks...${NC}"
    
    LOCAL_NAVIT="$HOME/.navit/maps"
    mkdir -p "$LOCAL_NAVIT"
    
    for bin_file in "$NAVIT_DIR"/*.bin; do
        [[ ! -f "$bin_file" ]] && continue
        
        filename=$(basename "$bin_file")
        local_link="$LOCAL_NAVIT/$filename"
        
        # Remove old symlink if exists
        [[ -L "$local_link" ]] && rm "$local_link"
        
        # Create symlink (don't overwrite real files)
        if [[ ! -f "$local_link" ]]; then
            ln -s "$bin_file" "$local_link"
            echo -e "  ${GREEN}✓${NC} $filename -> $bin_file"
        fi
    done
    echo ""
fi

echo -e "${CYAN}========================================"
echo -e " Conversion complete!"
echo -e " ${GREEN}Converted: $CONVERTED${NC}"
[[ $SKIPPED -gt 0 ]] && echo -e " ${YELLOW}Skipped (existing): $SKIPPED${NC}"
[[ $FAILED -gt 0 ]] && echo -e " ${RED}Failed: $FAILED${NC}"
echo -e "========================================${NC}"
echo ""
