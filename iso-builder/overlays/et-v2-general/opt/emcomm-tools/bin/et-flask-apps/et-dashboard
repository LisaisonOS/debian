    def on_category_toggle(self, widget, cat_id, cat_box):
        """Toggle category expansion (accordion - only one open at a time)"""
        is_currently_expanded = self.expanded_categories.get(cat_id, False)
        
        # Close all categories first
        for key in self.expanded_categories:
            self.expanded_categories[key] = False
        
        # Toggle the clicked one (if it was closed, open it)
        if not is_currently_expanded:
            self.expanded_categories[cat_id] = True
        
        self.rebuild_mode_section()
    
    def on_mode_clicked(self, widget, mode):
        """Launch selected mode via supervisor IPC."""
        mode_id = mode['id']
        mode_name = mode['name']
        params = {}

        # BBS clients need modem selection (restores v1 behavior)
        if mode_id == 'bbs-client-qttermtcp':
            modems = ['1200', '9600', '300']
            vara_fm = os.path.expanduser(
                "~/.wine32/drive_c/VARA FM/VARAFM.exe")
            vara_hf = os.path.expanduser(
                "~/.wine32/drive_c/VARA/VARA.exe")
            if os.path.isfile(vara_fm):
                modems.append('vara-fm')
            if os.path.isfile(vara_hf):
                modems.append('vara-hf')
            modem = self.show_modem_dialog("QtTermTCP", modems)
            if modem is None:
                return
            if modem == '9600':
                self._show_9600_warning()
            params["modem"] = modem

        elif mode_id == 'bbs-client-paracon':
            modem = self.show_modem_dialog("Paracon", ['1200', '9600', '300'])
            if modem is None:
                return
            if modem == '9600':
                self._show_9600_warning()
            params["modem"] = modem

        elif mode_id == 'bbs-server':
            modems = ['300', '1200', '9600']
            vara_fm = os.path.expanduser(
                "~/.wine32/drive_c/VARA FM/VARAFM.exe")
            vara_hf = os.path.expanduser(
                "~/.wine32/drive_c/VARA/VARA.exe")
            if os.path.isfile(vara_fm):
                modems.append('vara-fm')
            if os.path.isfile(vara_hf):
                modems.append('vara-hf')
            modem = self.show_modem_dialog("BBS Server", modems)
            if modem is None:
                return
            if modem == '9600':
                self._show_9600_warning()
            params["modem"] = modem

        print(f"Launching mode: {mode_name} ({mode_id})")

        # Add to recent
        self.add_to_recent(mode_id)

        # Update UI to show starting state
        starting = "Démarrage de" if self.language == 'fr' else "Starting"
        self.current_mode_label.set_text(f"→ {starting} {mode_name}...")

        # Start mode via supervisor in background thread
        def _do_start():
            resp = self.supervisor.start_mode(mode_id, params=params or None)
            if resp is None:
                err_title = "Erreur du superviseur" if self.language == 'fr' else "Supervisor Error"
                err_msg = "et-supervisor n'est pas en cours." if self.language == 'fr' else "et-supervisor is not running."
                GLib.idle_add(lambda: self.show_error_dialog(err_title, err_msg))
                GLib.idle_add(
                    lambda: self.current_mode_label.set_text(""))
            elif resp.get("status") != "ok":
                msg = resp.get("message", "Unknown error")
                fail = "Échec du démarrage de" if self.language == 'fr' else "Failed to start"
                GLib.idle_add(lambda: self.show_error_dialog(
                    f"{fail} {mode_name}", msg))
                GLib.idle_add(
                    lambda: self.current_mode_label.set_text(""))
            else:
                GLib.idle_add(
                    lambda: self.current_mode_label.set_text(
                        f"● {mode_name}"))

        threading.Thread(target=_do_start, daemon=True).start()

    def on_stop_clicked(self, widget):
        """Stop the current mode via supervisor IPC."""
        stopping = "Arrêt en cours..." if self.language == 'fr' else "Stopping..."
        self.current_mode_label.set_text(f"→ {stopping}")
        self.stop_btn.hide()
        self.key_btn.hide()

        def _do_stop():
            resp = self.supervisor.stop()
            if resp and resp.get("status") == "ok":
                GLib.idle_add(
                    lambda: self.current_mode_label.set_text(""))
            else:
                msg = resp.get("message", "Unknown error") if resp else "Supervisor not running"
                stop_fail = "Échec de l'arrêt" if self.language == 'fr' else "Stop failed"
                GLib.idle_add(lambda: self.show_error_dialog(stop_fail, msg))

        threading.Thread(target=_do_stop, daemon=True).start()

