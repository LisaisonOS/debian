    def on_monitor_changed(self, display, monitor=None):
        """Handle monitor/resolution changes"""
        self.monitor = display.get_primary_monitor() or display.get_monitor(0)
        if self.monitor:
            # Reconnect geometry signals to new monitor
            self.monitor.connect("notify::geometry", self.on_geometry_notify)
            self.monitor.connect("notify::scale-factor", self.on_geometry_notify)
            self.handle_screen_change()
    
    def on_geometry_notify(self, monitor, pspec):
        """Handle monitor geometry or scale factor changes (Approach 3)"""
        print(f"Monitor property changed: {pspec.name}")
        # Use idle_add to avoid processing during signal emission
        GLib.idle_add(self.handle_screen_change)
    
    def on_configure_event(self, widget, event):
        """Handle window configuration changes (Approach 1)"""
        expected_x = self.screen_x + self.screen_width - self.panel_width - self.margin
        current_x = event.x

        # If significantly off position (more than 20px), something changed
        if abs(current_x - expected_x) > 20:
            print(f"Position drift detected: expected x={expected_x}, got x={current_x}")
            GLib.timeout_add(100, self.handle_screen_change)

        return False  # Allow event to propagate

    def handle_screen_change(self):
        """Central handler for any screen/geometry change"""
        if not self.monitor:
            self.monitor = self.display.get_primary_monitor() or self.display.get_monitor(0)

        if not self.monitor:
            return False

        workarea = self.monitor.get_workarea()
        new_width = workarea.width
        new_height = workarea.height
        new_x_off = workarea.x
        new_y_off = workarea.y

        # Apply fractional scaling correction (X root may be smaller)
        x_root_w = self.screen.get_width()
        x_root_h = self.screen.get_height()
        if x_root_w < new_width:
            new_width = x_root_w
            new_height = min(new_height, x_root_h)

        print(f"Screen check: {new_width}x{new_height} at ({new_x_off},{new_y_off})")

        size_changed = (new_width != self.screen_width or new_height != self.screen_height)

        if size_changed:
            print(f"Screen size changed: {self.screen_width}x{self.screen_height} -> {new_width}x{new_height}")
            self.screen_width = new_width
            self.screen_height = new_height
            self.screen_x = new_x_off
            self.screen_y = new_y_off
            self.calculate_adaptive_sizes()
            self.apply_css()
            self.set_size_request(self.panel_width, -1)
            self.resize(self.panel_width, 1)
            hints = Gdk.Geometry()
            hints.min_width = self.panel_width
            hints.max_width = self.panel_width
            hints.max_height = self.screen_height
            self.set_geometry_hints(None, hints,
                                    Gdk.WindowHints.MIN_SIZE | Gdk.WindowHints.MAX_SIZE)
            self.rebuild_ui()

        # Always reposition to correct location
        new_x = self.screen_x + self.screen_width - self.panel_width - self.margin
        new_y = self.screen_y + self.margin
        self.move(new_x, new_y)
        self._last_expected_x = new_x

        # Trigger height recalculation
        GLib.idle_add(self.auto_resize_height)

        return False  # Don't repeat if called from timeout
    
    def rebuild_ui(self):
        """Rebuild entire UI"""
        for child in self.main_box.get_children():
            self.main_box.remove(child)
        self.apply_css()
        self.build_ui()
        self.show_all()
        # Auto-resize after a short delay to let GTK calculate sizes
        GLib.idle_add(self.auto_resize_height)
    
    def rebuild_mode_section(self):
        """Rebuild just the mode section"""
        if hasattr(self, 'mode_container'):
            self._filtered_categories = self._fetch_filtered_categories()
            for child in self.mode_container.get_children():
                self.mode_container.remove(child)
            self.build_mode_selector(self.mode_container)
            self.mode_container.show_all()
            # Auto-resize after rebuild
            GLib.idle_add(self.auto_resize_height)
    
