    # === Flask App Launcher ===
    def launch_flask_app(self, app_name):
        """Launch a Flask/PyWebView app (prevent double-launch)"""
        # Check if already running
        if app_name in self.running_apps:
            proc = self.running_apps[app_name]
            if proc.poll() is None:  # Still running
                print(f"{app_name} is already running")
                return
            else:
                # Process finished, remove from tracking
                del self.running_apps[app_name]
        
        app_info = FLASK_APPS.get(app_name)
        if not app_info:
            return
        
        script = app_info['script']
        dashboard_dir = os.path.dirname(os.path.abspath(__file__))
        
        locations = [
            f"{dashboard_dir}/{app_name}/{script}",
            f"{FLASK_APPS_DIR}/{app_name}/{script}",
            f"/opt/emcomm-tools/share/{app_name}/{script}",
            os.path.expanduser(f"~/{app_name}/{script}"),
        ]
        
        for path in locations:
            if os.path.exists(path):
                proc = subprocess.Popen(["python3", path],
                               cwd=os.path.dirname(path),
                               start_new_session=True)
                self.running_apps[app_name] = proc
                return
        
        print(f"Could not find {app_name}")
    
    def on_radio_clicked(self, widget):
        self.launch_flask_app('et-radio')
    
    def on_track_toggled(self, button):
        """Toggle GPS tracking mode."""
        if button.get_active():
            # Start tracking
            if not os.path.exists("/tmp/et-gps-connected"):
                button.set_active(False)
                return
            self.tracking_active = True
            self._tracking_stop.clear()
            # Write flag file for other apps (et-repeater)
            try:
                with open('/tmp/et-gps-tracking', 'w') as f:
                    f.write('1')
            except Exception:
                pass
            self.tracking_thread = threading.Thread(
                target=self._tracking_worker, daemon=True)
            self.tracking_thread.start()
            button.get_style_context().add_class("track-active")
        else:
            # Stop tracking
            self.tracking_active = False
            self._tracking_stop.set()
            self._tracking_grid = ''
            # Remove flag file
            try:
                os.remove('/tmp/et-gps-tracking')
            except Exception:
                pass
            button.get_style_context().remove_class("track-active")

    def _tracking_worker(self):
        """Background thread: read GPS, update grid in user.json."""
        last_grid = ''
        while not self._tracking_stop.is_set():
            lat, lon = read_gps_position()
            if lat is not None and lon is not None:
                grid = latlon_to_grid(lat, lon)
                self._tracking_grid = grid

                # Only write to user.json if grid changed
                if grid != last_grid:
                    last_grid = grid
                    try:
                        config = {}
                        if ET_CONFIG_FILE.exists():
                            with open(ET_CONFIG_FILE, 'r') as f:
                                config = json.load(f)
                        config['grid'] = grid
                        config['latitude'] = str(round(lat, 6))
                        config['longitude'] = str(round(lon, 6))
                        ET_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
                        with open(ET_CONFIG_FILE, 'w') as f:
                            json.dump(config, f, indent=2)
                    except Exception as e:
                        print(f"[TRACK] Error updating user.json: {e}")

            self._tracking_stop.wait(15)  # Update every 15 seconds

    def on_user_clicked(self, widget):
        self.launch_flask_app('et-user')


