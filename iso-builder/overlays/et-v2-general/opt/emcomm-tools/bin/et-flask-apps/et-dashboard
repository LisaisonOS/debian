    def auto_resize_height(self):
        """Auto-adjust window height to fit content, using available screen space"""
        # Force GTK to recalculate layout before measuring
        self.main_box.queue_resize()
        self.main_box.check_resize()

        # Get natural size of content
        min_height, nat_height = self.main_box.get_preferred_height()

        # Add padding for window chrome
        target_height = nat_height + (self.padding * 2) + 10

        # Max height: full screen minus top margin and taskbar
        taskbar_height = 50 if self.screen_width >= 1920 else 45
        max_height = self.screen_height - self.margin - taskbar_height

        # Use as much height as content needs, up to max
        final_height = min(target_height, max_height)

        # Resize window and reposition to maintain right-margin alignment
        self.resize(self.panel_width, final_height)
        self.move(self.screen_x + self.screen_width - self.panel_width - self.margin,
                  self.screen_y + self.margin)

        return False  # Don't repeat
    
