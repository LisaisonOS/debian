    def _update_supervisor_status(self):
        """Query supervisor for mode and process status."""
        resp = self.supervisor.status()

        # Clear old process labels
        for child in self.process_box.get_children():
            self.process_box.remove(child)

        if resp is None:
            self.stop_btn.hide()
            self.key_btn.hide()
            self._active_mode_id = None
            return

        mode_id = resp.get("mode")
        mode_name = resp.get("mode_name")
        processes = resp.get("processes", [])
        self._active_mode_id = mode_id

        if not mode_id:
            # No mode running — hide stop/key buttons, clear label
            self.stop_btn.hide()
            self.key_btn.hide()
            # Only clear if not mid-start
            current = self.current_mode_label.get_text()
            if current and not current.startswith("→"):
                self.current_mode_label.set_text("")
            self._last_crash_notified = None
            return

        # Show human-readable mode name and STOP button
        self.current_mode_label.set_text(f"● {mode_name or mode_id}")
        self.stop_btn.show()

        # Show key button only for chattervox mode
        if mode_id in ("chat-chattervox", "chat-chattervox-bt"):
            self.key_btn.show()
        else:
            self.key_btn.hide()

        # Show each process in the chain
        for p in processes:
            state = p["state"]
            name = p["name"]
            pid = p.get("pid", "")

            if state == "RUNNING":
                color = "#00CC00"
                symbol = "\u25cf"
            elif state in ("CRASHED", "FAILED"):
                color = "#CC0000"
                symbol = "\u2717"
            elif state == "STOPPED":
                color = "#888888"
                symbol = "\u25cb"
            else:
                color = "#888888"
                symbol = "\u25cb"

            markup = f"<span foreground='{color}'>{symbol}</span> "
            markup += f"<span foreground='#888888'>{name}</span>"
            if pid and state == "RUNNING":
                markup += f" <span foreground='#666666'>({pid})</span>"

            lbl = Gtk.Label()
            lbl.set_halign(Gtk.Align.START)
            lbl.get_style_context().add_class("process-label")
            lbl.set_markup(markup)
            self.process_box.pack_start(lbl, False, False, 0)

        self.process_box.show_all()

        # Crash notification — only for actual crashes, not normal exits
        crashed = [p for p in processes if p["state"] == "CRASHED"]
        crash_key = f"{mode_id}:{','.join(p['name'] for p in crashed)}"
        if crashed and crash_key != self._last_crash_notified:
            self._last_crash_notified = crash_key
            names = ", ".join(p["name"] for p in crashed)
            crash_msg = f"Processus planté : {names}" if self.language == 'fr' else f"Process crashed: {names}"
            subprocess.Popen(
                ["notify-send", "-u", "critical", "-i", "dialog-error",
                 "LiaisonOS", crash_msg])
    
