    def _read_version(self):
        """Read LiaisonOS version from manifest.json, fallback to version.txt."""
        try:
            import json
            manifest = json.loads(Path("/opt/emcomm-tools/manifest.json").read_text())
            return manifest.get("version", "")
        except Exception:
            try:
                return Path("/opt/emcomm-tools/version.txt").read_text().strip()
            except Exception:
                return ""

    def _reload_version(self):
        """Reload version label from manifest.json (triggered by SIGUSR1)."""
        version_str = self._read_version()
        if version_str and hasattr(self, 'version_label'):
            self.version_label.set_text(f"LiaisonOS v{version_str}")
        return False

