def latlon_to_grid(lat, lon):
    """Convert latitude/longitude to 6-char Maidenhead grid square."""
    lon = lon + 180
    lat = lat + 90
    field_lon = int(lon / 20)
    field_lat = int(lat / 10)
    square_lon = int((lon - field_lon * 20) / 2)
    square_lat = int((lat - field_lat * 10) / 1)
    sub_lon = int((lon - field_lon * 20 - square_lon * 2) / (2 / 24))
    sub_lat = int((lat - field_lat * 10 - square_lat * 1) / (1 / 24))
    return (chr(ord('A') + field_lon) + chr(ord('A') + field_lat) +
            str(square_lon) + str(square_lat) +
            chr(ord('a') + sub_lon) + chr(ord('a') + sub_lat))


def read_gps_position():
    """Read current GPS position from gpsd via gpspipe. Returns (lat, lon) or (None, None)."""
    try:
        result = subprocess.run(
            ['gpspipe', '-w', '-n', '5'],
            capture_output=True, text=True, timeout=5)
        for line in result.stdout.strip().split('\n'):
            if '"lat"' in line and '"lon"' in line:
                data = json.loads(line)
                lat = data.get('lat')
                lon = data.get('lon')
                if lat is not None and lon is not None:
                    return float(lat), float(lon)
    except Exception:
        pass
    return None, None


class SupervisorClient:
    """IPC client for et-supervisor daemon."""

    def send_command(self, cmd_dict, timeout=3):
        """Send a command to supervisor, return response dict or None."""
        if not os.path.exists(SUPERVISOR_SOCK):
            return None
        try:
            sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            sock.settimeout(timeout)
            sock.connect(SUPERVISOR_SOCK)
            sock.sendall(json.dumps(cmd_dict).encode() + b"\n")
            data = sock.recv(8192)
            sock.close()
            return json.loads(data.decode("utf-8"))
        except (ConnectionRefusedError, socket.timeout, OSError,
                json.JSONDecodeError):
            return None

    def status(self):
        return self.send_command({"cmd": "status"})

    def start_mode(self, mode_id, params=None):
        msg = {"cmd": "start-mode", "mode": mode_id}
        if params:
            msg["params"] = params
        return self.send_command(msg, timeout=120)

    def stop(self):
        return self.send_command({"cmd": "stop"}, timeout=10)

    def list_modes(self):
        return self.send_command({"cmd": "list-modes"})


def get_wine_env():
    """
    Get environment dictionary with WINEPREFIX set for Wine apps.
    
    CRITICAL: .bash_profile sets WINEPREFIX in terminals, but subprocess.Popen
    doesn't load profiles. Without this, Wine looks in ~/.wine instead of ~/.wine32,
    causing VARA and other Wine apps to fail with "DLL not found" errors.
    """
    env = os.environ.copy()
    env['WINEPREFIX'] = os.path.expanduser('~/.wine32')
    env['WINEARCH'] = 'win32'
    return env


def wait_for_port(port, host='localhost', timeout=30):
    """
    Wait until a TCP port is accepting connections.
    Returns True if port is ready, False if timeout.
    """
    print(f"Waiting for port {port} to be ready...")
    elapsed = 0
    while elapsed < timeout:
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(1)
            sock.connect((host, port))
            sock.close()
            print(f"Port {port} is ready!")
            return True
        except (socket.error, socket.timeout):
            time.sleep(0.5)
            elapsed += 0.5
    print(f"Timeout waiting for port {port}")
    return False


def check_radio_ready():
    """
    Check if radio is ready by testing if rigctld is listening on port 4532.
    When radio is plugged in, udev automatically starts rigctld.
    Returns (success, message)
    """
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(2)
        sock.connect(('localhost', 4532))
        sock.close()
        return True, "ok"
    except:
        return False, "no_radio"


def start_and_wait_for_service(service_name, timeout=30, interval=0.5, wait_port=None):
    """
    Start a systemd user service and wait until it's active.
    Optionally wait for a TCP port to be ready.
    Returns (success, message)
    """
    print(f"Starting {service_name}...")
    
    # Start the service
    result = subprocess.run(
        ["systemctl", "--user", "start", service_name],
        capture_output=True, text=True
    )
    
    if result.returncode != 0:
        return False, f"Failed to start {service_name}: {result.stderr}"
    
    # Wait for it to become active
    elapsed = 0
    while elapsed < timeout:
        check = subprocess.run(
            ["systemctl", "--user", "is-active", "--quiet", service_name],
            capture_output=True
        )
        if check.returncode == 0:
            # Service is active
            # Verify it didn't fail immediately after starting
            check2 = subprocess.run(
                ["systemctl", "--user", "is-failed", "--quiet", service_name],
                capture_output=True
            )
            if check2.returncode == 0:
                return False, f"{service_name} failed after starting"
            
            print(f"{service_name} is active")
            
            # If a port was specified, wait for it to be ready
            if wait_port:
                if not wait_for_port(wait_port, timeout=timeout):
                    return False, f"{service_name} started but port {wait_port} not ready"
            
            return True, f"{service_name} started successfully"
        
        time.sleep(interval)
        elapsed += interval
    
    return False, f"Timeout waiting for {service_name}"

