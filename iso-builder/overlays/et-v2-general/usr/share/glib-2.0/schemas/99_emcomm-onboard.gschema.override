[org.onboard]
start-minimized=true
show-status-icon=true
theme='/usr/share/onboard/themes/EmComm.theme'

[org.onboard.window]
docking-enabled=true
docking-edge='bottom'
docking-shrink-workarea=true
force-to-top=false
transparency=0.0
window-decoration=false
window-state-sticky=true

[org.onboard.window.landscape]
dock-expand=true
dock-height=205
dock-width=700

[org.onboard.window.portrait]
dock-expand=true
dock-height=200
dock-width=600
